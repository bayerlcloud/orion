# Orion — variáveis de ambiente
# Copie para .env e preencha os valores

# Servidor
PORT=8088

# Caminhos (opcionais — sobrescreve os defaults do código)
# WORKSPACE_DIR=/config/workspace/orion
# DB_PATH=./data/memory.db
# NOTES_DIR=/config/workspace/notes
# CLAUDE_MEM_DIR=/config/.claude/projects/-config-workspace/memory
# CLAUDE_MD=/config/.claude/CLAUDE.md

# WhatsApp / Evolution API
EVOLUTION_API_URL=https://evo.example.com
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=
WHATSAPP_OWNER_JID=

# Anthropic
ANTHROPIC_MODEL=claude-sonnet-4-6

# Painel externo (opcional)
PANEL_TOKEN=
PANEL_API_URL=http://localhost:9099

# Owner padrão (criado no primeiro boot se a tabela users estiver vazia)
OWNER_USERNAME=admin
OWNER_DISPLAY_NAME=Admin
OWNER_INITIAL_PASSWORD=changeMe!
