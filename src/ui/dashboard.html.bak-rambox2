        </div>

        <div class="box">
          <div class="box-h">📁 Arquivos conhecidos — clique para ler/editar</div>
          <div id="cmd-file-list" style="padding:.5rem 0"></div>
        </div>

        <div id="cmd-editor-wrap" style="display:none;margin-top:1rem">
          <div class="box">
            <div class="box-h">
              <span id="cmd-editor-title">editando…</span>
              <div style="display:flex;gap:.5rem">
                <button class="btn solid" onclick="saveCmdMd()">💾 Salvar</button>
                <button class="btn" onclick="closeCmdEditor()">✕ Fechar</button>
              </div>
            </div>
            <div style="padding:.8rem">
              <textarea id="cmd-editor-ta" style="width:100%;height:480px;background:#0a0a0f;border:1px solid var(--line);border-radius:8px;padding:12px;color:var(--txt);font-family:monospace;font-size:.8rem;resize:vertical;outline:none;line-height:1.6"></textarea>
