<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Orion — Dashboard</title>
<style>
  :root {
    --bg:#0a0a0f; --side:#0d0d14; --panel:#111118; --panel2:#1a1a28; --line:#1e1e2e;
    --txt:#e5e7eb; --mut:#6b7280; --accent:#6366f1; --accent2:#8b5cf6;
    --green:#22c55e; --yellow:#f59e0b; --red:#ef4444; --blue:#5b9dff; --purple:#a78bfa;
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  body { background:var(--bg); color:var(--txt); font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif; display:flex; height:100vh; overflow:hidden; }
  a { color:inherit; text-decoration:none; }
  ::-webkit-scrollbar{width:4px} ::-webkit-scrollbar-thumb{background:var(--line)}

  /* Sidebar: estilo único vem do SIDEBAR_CSS injetado pelo server.js (renderSidebar).
     Não redefinir .sidebar/.nav-item aqui — causava menus divergentes entre páginas. */

  /* ── Main ── */
  .main { flex:1; overflow-y:auto; display:flex; flex-direction:column; min-height:0; }
  .view { display:none; flex:1; flex-direction:column; min-height:0; }
  .view.active { display:flex; }
  .topbar { padding:16px 24px; border-bottom:1px solid var(--line); display:flex; align-items:center; justify-content:space-between; flex-shrink:0; }
  .topbar-title { font-size:16px; font-weight:700; }
  .topbar-sub   { font-size:12px; color:var(--mut); margin-top:2px; }
  .usage-group { display:flex; gap:16px; align-items:center; }
  .usage-item { display:flex; flex-direction:column; align-items:flex-end; gap:3px; }
  .usage-item .u-label { font-size:10px; text-transform:uppercase; letter-spacing:.05em; color:var(--mut); }
  .usage-item .u-row { display:flex; align-items:center; gap:6px; }
  .usage-item .u-bar { width:72px; height:4px; background:var(--line); border-radius:2px; overflow:hidden; }
  .usage-item .u-fill { height:100%; border-radius:2px; transition:width .6s; }
  .usage-item .u-pct { font-size:12px; font-weight:700; color:#e2e8f0; min-width:30px; text-align:right; }
  .usage-item .u-reset { font-size:10px; color:var(--mut); }
  .content { padding:24px; flex:1; overflow-y:auto; }
  .content::-webkit-scrollbar{width:4px} .content::-webkit-scrollbar-thumb{background:var(--line)}

  /* ── Orion cards ── */
  .stat-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(180px,1fr)); gap:14px; margin-bottom:24px; }
  .stat { background:var(--panel); border:1px solid var(--line); border-radius:12px; padding:18px 20px; }
  .stat-label { font-size:11px; color:var(--mut); text-transform:uppercase; letter-spacing:.05em; margin-bottom:8px; }
  .stat-value { font-size:26px; font-weight:700; color:#fff; }
  .stat-sub   { font-size:11px; color:var(--mut); margin-top:4px; }
  .section { background:var(--panel); border:1px solid var(--line); border-radius:12px; padding:20px; margin-bottom:18px; }
  .section h2 { font-size:12px; font-weight:600; color:var(--mut); margin-bottom:14px; letter-spacing:.06em; text-transform:uppercase; }
  .wa-status { display:flex; align-items:center; gap:10px; }
  .dot { width:9px; height:9px; border-radius:50%; }
  .dot.green  { background:var(--green); box-shadow:0 0 7px var(--green); }
  .dot.red    { background:var(--red); box-shadow:0 0 7px var(--red); }
  .dot.yellow { background:var(--yellow); animation:blink 1.2s infinite; }
  @keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}
  .qr-wrap { text-align:center; padding:20px 0; }
  .qr-wrap img { border-radius:12px; max-width:220px; border:4px solid #fff; }
  .qr-hint { font-size:12px; color:var(--mut); margin-top:10px; }
  .badge-pill { display:inline-flex; align-items:center; padding:2px 9px; border-radius:20px; font-size:11px; font-weight:600; }
  .badge-pill.online     { background:#14532d; color:#86efac; }
  .badge-pill.offline    { background:#450a0a; color:#fca5a5; }
  .badge-pill.connecting { background:#451a03; color:#fcd34d; }
  .msg-list { display:flex; flex-direction:column; gap:6px; }
  .msg { background:#0f0f1a; border-radius:8px; padding:10px 12px; display:flex; justify-content:space-between; align-items:flex-start; gap:12px; }
  .msg-role { font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:.05em; min-width:60px; }
  .msg-role.user      { color:var(--accent); }
  .msg-role.assistant { color:var(--green); }
  .msg-content { font-size:12px; color:#d1d5db; flex:1; word-break:break-word; }
  .msg-time    { font-size:10px; color:#4b5563; white-space:nowrap; }
  .empty { color:#4b5563; font-size:13px; text-align:center; padding:24px; }

  /* ── Panel styles ── */
  .p-content { padding:1.4rem 1.7rem; overflow-y:auto; flex:1; }
  .p-content::-webkit-scrollbar{width:4px} .p-content::-webkit-scrollbar-thumb{background:var(--line)}
  .p-head { display:flex; align-items:center; justify-content:space-between; gap:1rem; margin-bottom:1.3rem; flex-wrap:wrap; }
  .p-head h2 { font-size:1.25rem; font-weight:750; }
  .p-head .meta { font-size:.76rem; color:var(--mut); display:flex; gap:1rem; align-items:center; flex-wrap:wrap; }
  .countdown { color:var(--accent); font-weight:700; }
  .p-sec { display:none; } .p-sec.show { display:block; animation:fade .2s; }
  @keyframes fade{from{opacity:0;transform:translateY(4px)}to{opacity:1}}
  .alertbar { display:none; background:rgba(245,196,81,.12); border:1px solid var(--yellow); border-radius:10px; padding:.65rem 1rem; font-size:.82rem; color:var(--yellow); margin-bottom:1rem; }
  .alertbar.show { display:block; }
  .p-grid { display:grid; gap:.85rem; }
  .p-cards { grid-template-columns:repeat(auto-fit,minmax(150px,1fr)); margin-bottom:1.2rem; }
  .p-card { background:var(--panel); border:1px solid var(--line); border-radius:13px; padding:.95rem 1.05rem; }
  .p-card .l { font-size:.7rem; color:var(--mut); text-transform:uppercase; letter-spacing:.5px; font-weight:600; margin-bottom:.4rem; }
  .p-card .v { font-size:1.55rem; font-weight:750; letter-spacing:-.5px; }
  .p-card .sub { font-size:.72rem; color:var(--mut); margin-top:.2rem; }
  .pbar { height:6px; background:var(--panel2); border-radius:4px; overflow:hidden; margin-top:.55rem; }
  .pbar>i { display:block; height:100%; border-radius:4px; transition:.5s; }
  .loads { grid-template-columns:repeat(3,1fr); margin-bottom:1.2rem; }
  .lc { background:var(--panel); border:1px solid var(--line); border-radius:13px; padding:.8rem 1rem; text-align:center; }
  .lc .n { font-size:1.7rem; font-weight:750; }
  .box { background:var(--panel); border:1px solid var(--line); border-radius:13px; overflow:hidden; margin-bottom:1.2rem; }
  .box-h { padding:.7rem 1rem; font-size:.78rem; font-weight:700; text-transform:uppercase; letter-spacing:.6px; color:var(--mut); border-bottom:1px solid var(--line); display:flex; justify-content:space-between; align-items:center; }
  table { width:100%; border-collapse:collapse; }
  th { font-size:.7rem; font-weight:700; color:var(--mut); text-align:left; padding:.55rem 1rem; border-bottom:1px solid var(--line); text-transform:uppercase; letter-spacing:.6px; }
  td { font-size:.82rem; padding:.6rem 1rem; border-bottom:1px solid rgba(30,30,46,.6); }
  tr:last-child td { border-bottom:none; }
  tr:hover td { background:rgba(255,255,255,.02); }
  .mono { font-family:monospace; font-size:.79rem; }
  .btn { display:inline-flex; align-items:center; gap:.35rem; padding:.35rem .85rem; border-radius:8px; font-size:.78rem; font-weight:600; cursor:pointer; border:1px solid var(--line); background:var(--panel2); color:var(--txt); transition:.15s; }
  .btn:hover { border-color:var(--accent); color:var(--accent); }
  .btn.solid { background:var(--accent); color:#fff; border-color:transparent; }
  .btn.solid:hover { opacity:.88; }
  .btn.danger { background:#7f1d1d; color:#fca5a5; border-color:transparent; }
  .btn.danger:hover { opacity:.85; }
  .btn.g { background:#14532d; color:#86efac; border-color:transparent; }
  .btn.r { background:#450a0a; color:#fca5a5; border-color:transparent; }
  .btn:disabled { opacity:.45; cursor:not-allowed; }
  .row { display:flex; gap:.4rem; align-items:center; }
  .pill { font-size:.7rem; font-weight:700; padding:.15rem .55rem; border-radius:20px; background:var(--panel2); }
  .pill.on  { color:var(--green); } .pill.stop { color:var(--red); } .pill.warn { color:var(--yellow); }
  .chip { font-size:.64rem; background:var(--panel2); border:1px solid var(--line); color:var(--mut); padding:.1rem .4rem; border-radius:5px; margin-left:.3rem; }
  .tile { background:var(--panel); border:1px solid var(--line); border-radius:11px; padding:.85rem 1rem; cursor:default; text-decoration:none; display:block; }
  .tile:hover { border-color:var(--accent); }
  .tile .t { font-size:.82rem; font-weight:700; display:flex; align-items:center; margin-bottom:.3rem; }
  .tile .d { font-size:.72rem; color:var(--mut); line-height:1.4; }
  .tiles { grid-template-columns:repeat(auto-fit,minmax(180px,1fr)); margin-bottom:1.2rem; }
  .ct-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(220px,1fr)); gap:.65rem; margin-bottom:1.4rem; }
  .ct-card { background:var(--panel); border:1px solid var(--line); border-radius:11px; padding:.85rem 1rem; }
  .ct-head { display:flex; align-items:center; gap:.4rem; margin-bottom:.65rem; }
  .ct-dot { width:8px; height:8px; border-radius:50%; flex-shrink:0; }
  .ct-name { font-size:.82rem; font-weight:700; flex:1; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
  .ct-img { font-size:.62rem; color:var(--mut); max-width:90px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
  .ct-row { display:flex; align-items:center; gap:.4rem; margin-bottom:.28rem; }
  .ct-label { font-size:.64rem; color:var(--mut); width:28px; flex-shrink:0; text-transform:uppercase; letter-spacing:.3px; }
  .ct-bar { flex:1; height:5px; background:rgba(255,255,255,.07); border-radius:3px; overflow:hidden; }
  .ct-bar i { display:block; height:100%; border-radius:3px; transition:width .5s; }
  .ct-val { font-size:.7rem; font-weight:600; width:56px; text-align:right; }
  .proj { background:var(--panel); border:1px solid var(--line); border-radius:12px; padding:1rem 1.1rem; margin-bottom:.85rem; }
  .proj-h { display:flex; align-items:center; flex-wrap:wrap; gap:.4rem; margin-bottom:.7rem; font-weight:700; }
  .checklist { display:flex; gap:.5rem; flex-wrap:wrap; margin-bottom:.5rem; }
  .ck { font-size:.7rem; padding:.15rem .55rem; border-radius:20px; }
  .ck.on  { background:#14532d; color:#86efac; } .ck.off { background:#450a0a; color:#fca5a5; }
  .proj-sub { font-size:.72rem; color:var(--mut); } .nest { font-size:.72rem; color:var(--mut); margin-top:.4rem; }
  .b100 { font-size:.72rem; color:var(--green); font-weight:700; } .bpend { font-size:.72rem; color:var(--yellow); }
  .search { width:100%; background:var(--panel); border:1px solid var(--line); border-radius:9px; padding:.6rem 1rem; color:var(--txt); font-size:.82rem; outline:none; margin-bottom:.9rem; }
  .search:focus { border-color:var(--accent); }
  .md { background:var(--panel); border:1px solid var(--line); border-radius:13px; padding:1.5rem 1.8rem; line-height:1.75; font-size:.88rem; }
  .md h1,.md h2,.md h3 { margin:1.2rem 0 .5rem; }
  .md h1 { font-size:1.3rem; } .md h2 { font-size:1.05rem; } .md h3 { font-size:.9rem; color:var(--accent); }
  .md p { margin-bottom:.6rem; } .md ul { margin:.4rem 0 .8rem 1.5rem; } .md li { margin-bottom:.3rem; }
  .md hr { border:none; border-top:1px solid var(--line); margin:1rem 0; }
  .md table { margin:1rem 0; } .md code { background:var(--panel2); padding:.1rem .4rem; border-radius:5px; font-size:.8rem; }
  .md pre { background:var(--panel2); padding:.85rem; border-radius:9px; overflow-x:auto; margin:.8rem 0; }
  .md a { color:var(--blue); text-decoration:underline; }
  .legend { display:flex; gap:1.2rem; margin-bottom:.75rem; font-size:.75rem; color:var(--mut); }
  .legend .dot-s { display:inline-block; width:10px; height:10px; border-radius:50%; margin-right:.4rem; }
  .chart-wrap { background:var(--panel); border:1px solid var(--line); border-radius:13px; padding:1rem 1.2rem; margin-bottom:1rem; }
  .side-foot { margin-top:auto; font-size:.68rem; color:var(--mut); }
  #toast { position:fixed; bottom:1.5rem; right:1.5rem; background:var(--panel); border:1px solid var(--line); border-radius:10px; padding:.7rem 1.1rem; font-size:.83rem; font-weight:600; display:none; z-index:999; }
  #toast.show { display:block; }

  /* ── Documentação ── */
  .doc-sec { display:none; } .doc-sec.show { display:block; animation:fade .2s; }
  .flow-channel { background:#111118; border:1px solid #1e1e3a; border-radius:8px; padding:7px 14px; font-size:.75rem; color:#a5b4fc; font-weight:600; text-align:center; }
  .flow-arrow-center { text-align:center; color:#374151; font-size:1.1rem; margin:.1rem 0; }
  .flow-box { background:#0d0d1a; border:1px solid #1e1e3a; border-radius:12px; padding:14px 18px; text-align:center; margin:.2rem 0; }
  .flow-box-main { border-color:#6366f1; background:#0e0e20; }
  .flow-box-title { font-size:.9rem; font-weight:700; color:#e5e7eb; }
  .flow-box-sub { font-size:.72rem; color:#6b7280; margin-top:.3rem; font-family:monospace; }
  .flow-layer { background:#0d0d1a; border:1px solid; border-radius:10px; padding:12px 14px; display:flex; gap:10px; align-items:flex-start; }
  .flow-layer-num { width:22px; height:22px; border-radius:50%; background:#1a1a2e; border:1px solid #2d2d4e; display:flex; align-items:center; justify-content:center; font-size:.7rem; font-weight:700; color:#6b7280; flex-shrink:0; margin-top:1px; }
  .flow-layer-title { font-size:.82rem; font-weight:700; color:#e5e7eb; margin-bottom:.25rem; }
  .flow-layer-sub { font-size:.72rem; color:#9ca3af; line-height:1.45; margin-bottom:.3rem; }
  .flow-layer-tag { font-size:.65rem; font-family:monospace; color:#4b5563; background:#111118; padding:2px 6px; border-radius:4px; display:inline-block; }

  /* ── Home unificada: sub-nav + seções + widgets ── */
  .subnav { position:sticky; top:0; z-index:20; display:flex; gap:.4rem; flex-wrap:wrap; padding:11px 24px; background:rgba(10,10,15,.93); backdrop-filter:blur(8px); border-bottom:1px solid var(--line); }
  .subnav a { font-size:.73rem; font-weight:600; color:var(--mut); padding:5px 11px; border-radius:20px; border:1px solid var(--line); background:var(--panel); cursor:pointer; white-space:nowrap; transition:.12s; }
  .subnav a:hover { color:var(--txt); border-color:var(--accent); }
  .hsec { margin-bottom:2rem; scroll-margin-top:60px; }
  .hsec-h { font-size:1rem; font-weight:750; margin:0 0 1rem; display:flex; align-items:center; gap:.55rem; color:#fff; }
  .hsec-h .tag { font-size:.58rem; font-weight:700; background:#1a1a2e; color:var(--accent); padding:2px 7px; border-radius:5px; text-transform:uppercase; letter-spacing:.5px; }
  .hgrid2 { display:grid; grid-template-columns:repeat(auto-fit,minmax(330px,1fr)); gap:1rem; }
  .hgrid3 { display:grid; grid-template-columns:repeat(auto-fit,minmax(290px,1fr)); gap:1rem; }
  .wbox { background:var(--panel); border:1px solid var(--line); border-radius:13px; padding:1rem 1.1rem; }
  .wbox-h { font-size:.72rem; font-weight:700; text-transform:uppercase; letter-spacing:.5px; color:var(--mut); margin-bottom:.85rem; display:flex; align-items:center; gap:.4rem; }
  .wbox-h .n { margin-left:auto; font-size:.7rem; color:var(--accent); font-weight:700; }
  .pulse { display:flex; flex-direction:column; gap:.35rem; max-height:300px; overflow-y:auto; }
  .pulse-item { display:flex; gap:.5rem; align-items:flex-start; font-size:.74rem; padding:.35rem .5rem; border-radius:7px; background:#0f0f1a; }
  .pulse-dot { width:7px; height:7px; border-radius:50%; flex-shrink:0; margin-top:.32rem; }
  .pulse-txt { flex:1; color:#cbd5e1; word-break:break-word; line-height:1.35; }
  .pulse-t { color:#4b5563; font-size:.65rem; white-space:nowrap; }
  .sig { display:flex; gap:.5rem; align-items:flex-start; font-size:.76rem; padding:.42rem .55rem; border-radius:7px; margin-bottom:.35rem; color:#d1d5db; line-height:1.4; }
  .sig.ok { background:rgba(34,197,94,.08); } .sig.warn { background:rgba(245,158,11,.1); }
  .sig.action { background:rgba(99,102,241,.13); } .sig.info { background:#0f0f1a; }
  .sig .ic2 { flex-shrink:0; }
  .gauge { display:flex; align-items:center; gap:1rem; margin-bottom:.8rem; }
  .gauge .big { font-size:2.3rem; font-weight:800; line-height:1; }
  .minirow { display:flex; align-items:center; gap:.5rem; font-size:.74rem; margin-bottom:.32rem; }
  .minirow .ml { width:96px; color:var(--mut); flex-shrink:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
  .minirow .mb { flex:1; height:6px; background:var(--panel2); border-radius:4px; overflow:hidden; }
  .minirow .mb i { display:block; height:100%; border-radius:4px; transition:.5s; }
  .minirow .mv { width:46px; text-align:right; font-weight:700; font-size:.72rem; }
  .klist { display:flex; flex-direction:column; gap:.3rem; max-height:300px; overflow-y:auto; }
  .kitem { display:flex; gap:.5rem; align-items:center; font-size:.76rem; padding:.42rem .55rem; border-radius:7px; background:#0f0f1a; color:#cbd5e1; }
  .kitem b { color:#e5e7eb; font-weight:600; }
  .kmut { color:var(--mut); font-size:.7rem; white-space:nowrap; }
</style>
<style id="orion-redesign">
/* ORION-REDESIGN-2026-06-29 */
:root{
  --bg:#08080e; --panel:#0f0f18; --panel2:#16161f; --line:#22223a;
  --accent:#6366f1; --accent2:#8b5cf6; --mut:#7b8294;
}
/* fundo com profundidade (glow indigo/violeta) */
body{
  background:
    radial-gradient(1100px 560px at 82% -12%, rgba(99,102,241,.13), transparent 60%),
    radial-gradient(820px 460px at -5% 2%, rgba(139,92,246,.10), transparent 55%),
    var(--bg) !important;
}
::-webkit-scrollbar{width:9px;height:9px}
::-webkit-scrollbar-thumb{background:linear-gradient(var(--accent),var(--accent2));border-radius:9px;border:2px solid var(--bg)}
::-webkit-scrollbar-track{background:transparent}

/* ── Topbar = command center ── */
.topbar{
  padding:22px 28px; flex-wrap:wrap; gap:14px;
  border-bottom:1px solid var(--line);
  background:linear-gradient(180deg, rgba(99,102,241,.07), transparent 90%);
  backdrop-filter:blur(8px);
}
.topbar-title{
  font-size:21px; font-weight:850; letter-spacing:-.02em;
  background:linear-gradient(92deg,#ffffff,#c7d2fe 55%,#b39df9);
  -webkit-background-clip:text; background-clip:text; -webkit-text-fill-color:transparent;
}
.topbar-sub{ font-size:12px; margin-top:5px; color:var(--mut); }
.usage-group{ gap:22px; }
.usage-item .u-label{ font-size:9.5px; }
.usage-item .u-bar{ width:88px; height:5px; }
.usage-item .u-pct{ font-size:13px; }
.btn{
  border-radius:11px; padding:.55rem 1.05rem; font-weight:650;
  background:rgba(255,255,255,.05); border:1px solid var(--line);
  transition:transform .16s, box-shadow .16s, border-color .16s, background .16s;
}
.btn:hover{ transform:translateY(-1px); border-color:transparent;
  background:linear-gradient(135deg,var(--accent),var(--accent2)); color:#fff;
  box-shadow:0 6px 18px -4px rgba(99,102,241,.5); }

/* ── Chips (subnav) ── */
.subnav{ padding:13px 28px; gap:.5rem; background:rgba(8,8,14,.86); backdrop-filter:blur(10px); }
.subnav a{
  font-size:.76rem; font-weight:650; padding:6px 14px; border-radius:12px;
  background:rgba(255,255,255,.035); border:1px solid var(--line); color:var(--mut);
  transition:.18s;
}
.subnav a:hover{
  color:#fff; border-color:transparent; transform:translateY(-1px);
  background:linear-gradient(135deg,var(--accent),var(--accent2));
  box-shadow:0 6px 18px -5px rgba(99,102,241,.55);
}

/* ── Conteúdo centralizado ── */
.content{ padding:26px 26px 60px; max-width:none; margin:0; width:100%; }

/* ── Cabeçalho de seção com barra accent ── */
.hsec{ margin-bottom:2.8rem; animation:orRise .45s ease both; }
@keyframes orRise{ from{opacity:0;transform:translateY(10px)} to{opacity:1;transform:none} }
.hsec-h{
  font-size:1.18rem; font-weight:850; letter-spacing:-.01em; color:#fff;
  padding-bottom:.75rem; margin-bottom:1.3rem; border-bottom:1px solid var(--line); position:relative;
}
.hsec-h::after{
  content:''; position:absolute; left:0; bottom:-1px; width:58px; height:2.5px; border-radius:3px;
  background:linear-gradient(90deg,var(--accent),var(--accent2));
}
.hsec-h .tag{
  background:linear-gradient(135deg,rgba(99,102,241,.22),rgba(139,92,246,.22));
  color:#c7d2fe; border:1px solid rgba(99,102,241,.25);
}

/* ── Cards: profundidade unificada ── */
.wbox,.stat,.p-card,.box,.ct-card,.tile,.section,.chart-wrap,.lc,.proj,.md{
  background:linear-gradient(180deg,rgba(255,255,255,.028),rgba(255,255,255,0)), var(--panel);
  border:1px solid var(--line); border-radius:16px;
  box-shadow:0 1px 2px rgba(0,0,0,.35), 0 14px 34px -22px rgba(0,0,0,.8);
  transition:transform .18s, border-color .18s, box-shadow .18s;
}
/* lift nos cards pequenos */
.wbox:hover,.stat:hover,.p-card:hover,.ct-card:hover,.tile:hover,.lc:hover{
  transform:translateY(-3px); border-color:rgba(99,102,241,.55);
  box-shadow:0 16px 38px -16px rgba(99,102,241,.45);
}
/* glow sem pulo nos grandes */
.box:hover,.section:hover,.chart-wrap:hover{ border-color:rgba(99,102,241,.4); }

/* números com gradiente (só os grandes "ao vivo") */
.stat-value{
  font-size:30px;
  background:linear-gradient(135deg,#fff,#c7d2fe);
  -webkit-background-clip:text; background-clip:text; -webkit-text-fill-color:transparent;
}
.stat{ padding:20px 22px; }
.stat-label,.wbox-h,.box-h{ color:#8b93a7; }

/* tabelas */
.box{ overflow:hidden; }
th{ background:rgba(255,255,255,.025); }
tr:hover td{ background:rgba(99,102,241,.06); }

/* empty-state repaginado */
.empty{
  border:1px dashed var(--line); border-radius:13px; padding:22px;
  color:#5b6478; font-size:.8rem; background:rgba(255,255,255,.012);
}

/* badges/pills mais vivas */
.badge-pill.online{ box-shadow:0 0 0 1px rgba(34,197,94,.2) inset; }
</style>
<style id="orion-redesign-2">
/* ── Skeleton (shimmer) p/ contadores enquanto carregam/se quebrarem ── */
@keyframes orShimmer { 0%{background-position:-450px 0} 100%{background-position:450px 0} }
.skel { background:linear-gradient(90deg,#14141f 25%,#20202f 50%,#14141f 75%); background-size:900px 100%; animation:orShimmer 1.4s infinite linear; border-radius:10px; opacity:.7; }
.skel-card { height:84px; }
.skel-load { height:66px; }
.skel-ct   { height:96px; border-radius:12px; }
.skel-row td { padding:0 !important; }
.skel-row .skb { height:14px; margin:11px 14px; background:linear-gradient(90deg,#14141f 25%,#20202f 50%,#14141f 75%); background-size:900px 100%; animation:orShimmer 1.4s infinite linear; border-radius:6px; }

  .mfsel { background:#14141f; border:1px solid var(--line); color:var(--txt); border-radius:9px; padding:.4rem .7rem; font-size:.78rem; outline:none; cursor:pointer; }
  .mfsel:focus { border-color:var(--accent); }
  .mfr { background:#14141f; border:1px solid var(--line); color:var(--mut); border-radius:8px; padding:.35rem .7rem; font-size:.74rem; font-weight:600; cursor:pointer; transition:.15s; }
  .mfr:hover { color:#fff; border-color:var(--accent); }
  .mfr.active { background:linear-gradient(135deg,var(--accent),var(--accent2)); color:#fff; border-color:transparent; }

  /* ── 100% largura + compacto no mobile ── */
@media (max-width: 640px) {
  .content { padding: 14px 10px 48px !important; max-width: 100% !important; margin: 0 !important; }
  .topbar  { padding: 14px 14px !important; flex-wrap: wrap; gap: 10px !important; }
  .topbar-title { font-size: 18px !important; }
  .subnav  { padding: 9px 10px !important; gap: .35rem !important; }
  .subnav a { padding: 5px 10px !important; font-size: .72rem !important; }
  .hsec    { margin-bottom: 1.8rem !important; }
  .hsec-h  { font-size: 1.05rem !important; }
  .hgrid2, .hgrid3 { grid-template-columns: 1fr !important; gap: .75rem !important; }
  .p-cards { grid-template-columns: repeat(2, 1fr) !important; gap: .6rem !important; }
  .ct-grid { grid-template-columns: 1fr !important; }
  .stat-grid { grid-template-columns: repeat(2, 1fr) !important; gap: .6rem !important; }
  .usage-group { gap: 14px !important; }
  .wbox, .stat, .p-card, .box, .ct-card { border-radius: 14px !important; }
}
</style>
</head>
<body>

<!-- Sidebar -->
<!--SIDEBAR-->

<!-- Main content -->
<main class="main">

  <!-- ── Orion — Central (home unificada) ── -->
  <div class="view active" id="view-orion-dash">
    <div class="topbar">
      <div>
        <div class="topbar-title">Orion — Central</div>
        <div class="topbar-sub"><span id="uptime">carregando...</span> · servidor <span id="hUpdated">—</span> · ↻ <span class="countdown" id="cd">30</span>s</div>
      </div>
      <div style="display:flex;gap:1.1rem;align-items:center">
        <div class="usage-group" id="salim-group" style="display:none">
          <div class="usage-item">
            <div class="u-label">Sessão (5h)</div>
            <div class="u-row">
              <div class="u-bar"><div class="u-fill" id="salim-sess-fill" style="width:0%"></div></div>
              <div class="u-pct" id="salim-sess-pct">—</div>
            </div>
            <div class="u-reset" id="salim-sess-reset"></div>
          </div>
          <div class="usage-item">
            <div class="u-label">Semana (7d)</div>
            <div class="u-row">
              <div class="u-bar"><div class="u-fill" id="salim-week-fill" style="width:0%"></div></div>
              <div class="u-pct" id="salim-week-pct">—</div>
            </div>
            <div class="u-reset" id="salim-week-reset"></div>
          </div>
        </div>
        <button class="btn" onclick="refreshNow()">↻ Atualizar</button>
      </div>
    </div>

    <!-- sub-navegação por âncoras -->
    <div class="subnav">
      <a onclick="goSec('sec-servidor')">🖥️ Servidor</a>
      <a onclick="goSec('sec-projetos')">📦 Projetos</a>
      <a onclick="goSec('sec-metricas')">📊 Métricas</a>
      <a onclick="goSec('sec-vivo')">⚡ Ao vivo</a>
      <a onclick="goSec('sec-operacao')">🛠️ Operação</a>
      <a onclick="goSec('sec-conhecimento')">🧠 Conhecimento</a>
      <a onclick="goSec('sec-whatsapp')">📱 WhatsApp</a>
      <a onclick="goSec('sec-dns')">🌐 DNS</a>
      <a onclick="goSec('sec-bancos')">🗄️ Bancos</a>
      <a onclick="goSec('sec-historico')">📈 Histórico</a>
      <a onclick="goSec('sec-skills')">🔌 Skills & MCP</a>
      <a onclick="goSec('sec-notas')">📝 Notas</a>
      <a onclick="goSec('sec-claudemd')">📄 CLAUDE.md</a>
    </div>

    <div class="content">

      <!-- ═══ SERVIDOR ═══ -->
      <section class="hsec" id="sec-servidor">
        <h2 class="hsec-h">🖥️ Servidor <span class="tag">contabo</span></h2>
        <div class="alertbar" id="alertBar"></div>
        <div class="p-grid p-cards" id="ovCards"><div class="skel skel-card"></div><div class="skel skel-card"></div><div class="skel skel-card"></div><div class="skel skel-card"></div><div class="skel skel-card"></div><div class="skel skel-card"></div></div>
        <div class="p-grid loads" id="ovLoads"><div class="skel skel-load"></div><div class="skel skel-load"></div><div class="skel skel-load"></div></div>
        <div class="box"><div class="box-h">🔥 Top processos por CPU</div><table id="procT"><thead><tr><th>Processo</th><th>CPU</th><th>MEM</th></tr></thead><tbody><tr class="skel-row"><td colspan="3"><div class="skb"></div></td></tr><tr class="skel-row"><td colspan="3"><div class="skb"></div></td></tr><tr class="skel-row"><td colspan="3"><div class="skb"></div></td></tr><tr class="skel-row"><td colspan="3"><div class="skb"></div></td></tr></tbody></table></div>
        <div class="box-h" style="border:none;padding-left:0;margin-bottom:.75rem">🐳 Containers ativos</div>
        <div class="ct-grid" id="containerGrid"><div class="skel skel-ct"></div><div class="skel skel-ct"></div><div class="skel skel-ct"></div><div class="skel skel-ct"></div></div>
      </section>

      <section class="hsec" id="sec-projetos">
        <h2 class="hsec-h">📦 Projetos <span class="tag" id="nbProj">—</span></h2>
        <div class="row" style="margin-bottom:1rem;gap:.6rem">
          <button class="btn solid" onclick="act('pm2_startall')">▶️ Ligar todos</button>
          <button class="btn danger" onclick="act('pm2_stopall')">⏹️ Modo pânico</button>
        </div>
        <div class="box"><div class="box-h">▶️ Dev servers (pm2)<span id="devSum"></span></div><table id="devT"><thead><tr><th>Projeto</th><th>Status</th><th>RAM</th><th>CPU</th><th>Ações</th></tr></thead><tbody></tbody></table></div>
        <div class="box-h" style="border:none;padding-left:0">📦 Projetos & credenciais</div>
        <div id="projWrap"></div>
        <div class="box-h" style="border:none;padding-left:0;margin-top:1.2rem">🔧 Tools</div>
        <div class="p-grid tiles" id="toolsWrap"></div>
        <div class="box-h" style="border:none;padding-left:0;margin-top:1.2rem">🌐 Serviços & atalhos</div>
        <div class="p-grid tiles" id="ovSvc"></div>
      </section>

      <!-- ═══ ORION AO VIVO ═══ -->
      <section class="hsec" id="sec-metricas">
        <h2 class="hsec-h">📊 Métricas — consumo histórico</h2>
        <div class="wbox">
          <div style="display:flex;flex-wrap:wrap;gap:.5rem;align-items:center;margin-bottom:1rem">
            <select id="mfKind" class="mfsel"><option value="container">🐳 Containers</option><option value="pm2">▶️ Dev servers (pm2)</option><option value="server">🖥️ Servidor</option></select>
            <select id="mfName" class="mfsel"></select>
            <select id="mfMetric" class="mfsel"></select>
            <div style="display:flex;gap:.3rem;margin-left:auto">
              <button class="mfr active" data-r="1h">1h</button>
              <button class="mfr" data-r="1d">1 dia</button>
              <button class="mfr" data-r="1w">1 sem</button>
              <button class="mfr" data-r="1mo">1 mês</button>
            </div>
          </div>
          <svg id="metricChart" viewBox="0 0 1000 300" preserveAspectRatio="none" style="width:100%;height:300px"></svg>
          <p id="metricInfo" style="font-size:.74rem;color:var(--mut);margin-top:.5rem"></p>
        </div>
      </section>

      <section class="hsec" id="sec-vivo">
        <h2 class="hsec-h">⚡ Orion ao vivo</h2>
        <div class="stat-grid">
          <div class="stat"><div class="stat-label">Memórias</div><div class="stat-value" id="mem-count">—</div><div class="stat-sub" id="mem-types">—</div></div>
          <div class="stat"><div class="stat-label">Sessões</div><div class="stat-value" id="sess-count">—</div><div class="stat-sub">conversas ativas</div></div>
          <div class="stat"><div class="stat-label">Mensagens</div><div class="stat-value" id="msg-count">—</div><div class="stat-sub">total trocadas</div></div>
          <div class="stat"><div class="stat-label">Cron Jobs</div><div class="stat-value" id="cron-count">—</div><div class="stat-sub">agendamentos ativos</div></div>
        </div>
        <div class="hgrid3">
          <div class="wbox"><div class="wbox-h">🫀 Pulso do cérebro <span class="n" id="pulseN">live</span></div><div class="pulse" id="brainPulse"><div class="empty">conectando…</div></div></div>
          <div class="wbox"><div class="wbox-h">💚 Saúde da memória</div><div id="memHealth"><div class="empty">carregando…</div></div></div>
          <div class="wbox"><div class="wbox-h">🔔 Caixa de decisão <span class="n" id="inboxCount"></span></div><div id="decisionInbox"><div class="empty">carregando…</div></div></div>
        </div>
      </section>

      <!-- ═══ OPERAÇÃO ═══ -->
      <section class="hsec" id="sec-operacao">
        <h2 class="hsec-h">🛠️ Operação</h2>
        <div class="hgrid3">
          <div class="wbox"><div class="wbox-h">🟢 Sessões Claude ativas <span class="n" id="activeCount"></span></div><div class="klist" id="activeSessions"><div class="empty">carregando…</div></div></div>
          <div class="wbox"><div class="wbox-h">⏰ Próximos crons <span class="n" id="cronCount"></span></div><div class="klist" id="cronTimeline"><div class="empty">carregando…</div></div></div>
          <div class="wbox"><div class="wbox-h">⚡ Top skills aprendidas <span class="n" id="skillsCount"></span></div><div class="klist" id="topSkills"><div class="empty">carregando…</div></div></div>
        </div>
      </section>

      <!-- ═══ CONHECIMENTO ═══ -->
      <section class="hsec" id="sec-conhecimento">
        <h2 class="hsec-h">🧠 Conhecimento & memória</h2>
        <div class="hgrid2">
          <div class="wbox"><div class="wbox-h">📊 Composição da memória</div><div id="memGrowth"><div class="empty">carregando…</div></div></div>
          <div class="wbox"><div class="wbox-h">🕸️ Mini knowledge-graph</div><div id="miniGraph"><div class="empty">carregando…</div></div></div>
          <div class="wbox"><div class="wbox-h">📡 Atividade por canal</div><div id="channelActivity"><div class="empty">carregando…</div></div></div>
          <div class="wbox"><div class="wbox-h">💰 Uso & custo de IA</div><div id="aiCost"><div class="empty">carregando…</div></div></div>
          <div class="wbox"><div class="wbox-h">🔗 Cadeias causais</div><div class="klist" id="causalBox"><div class="empty">carregando…</div></div></div>
          <div class="wbox"><div class="wbox-h">🕰️ Índice temporal</div><div id="temporalBox"><div class="empty">carregando…</div></div></div>
          <div class="wbox"><div class="wbox-h">❓ Aprendizado ativo</div><div id="activeLearning"><div class="empty">carregando…</div></div></div>
          <div class="wbox"><div class="wbox-h">🧮 Qualidade da memória</div><div class="ct-grid" id="memQualityGrid" style="grid-template-columns:1fr"></div></div>
        </div>
      </section>

      <!-- ═══ WHATSAPP ═══ -->
      <section class="hsec" id="sec-whatsapp">
        <h2 class="hsec-h">📱 WhatsApp</h2>
        <div class="hgrid2">
          <div class="section" style="margin:0">
            <h2>Status da conexão</h2>
            <div class="wa-status">
              <div class="dot yellow" id="wa-dot"></div>
              <span id="wa-status-text">verificando...</span>
              <span class="badge-pill connecting" id="wa-badge">conectando</span>
            </div>
            <div id="qr-container" style="display:none">
              <div class="qr-wrap"><img id="qr-img" src="" alt="QR Code"><div class="qr-hint">Abra o WhatsApp → Dispositivos conectados → Conectar dispositivo</div></div>
            </div>
            <div class="p-grid p-cards" id="waCards" style="margin-top:1rem"></div>
          </div>
          <div class="section" style="margin:0">
            <h2>Últimas mensagens</h2>
            <div id="msg-list" class="msg-list"><div class="empty">Nenhuma mensagem ainda</div></div>
          </div>
        </div>
      </section>

      <!-- ═══ PROJETOS ═══ -->

      <!-- ═══ DNS ═══ -->
      <section class="hsec" id="sec-dns">
        <h2 class="hsec-h">🌐 DNS & domínios <span class="tag" id="nbDns">—</span></h2>
        <div class="p-grid p-cards" id="dnsCards" style="grid-template-columns:repeat(auto-fit,minmax(180px,1fr))"></div>
        <div class="box"><div class="box-h">🌐 Registros DNS — zona bayerl.cloud</div><table id="dnsT"><thead><tr><th>Subdomínio</th><th>Tipo</th><th>Aponta para</th><th>Destino</th></tr></thead><tbody></tbody></table></div>
      </section>

      <!-- ═══ BANCOS ═══ -->
      <section class="hsec" id="sec-bancos">
        <h2 class="hsec-h">🗄️ Bancos de dados</h2>
        <div class="box"><div class="box-h">🗄️ Projetos Supabase</div><table id="dbT"><thead><tr><th>Projeto</th><th>Região</th><th>Status</th><th>Criado</th></tr></thead><tbody></tbody></table></div>
      </section>

      <!-- ═══ HISTÓRICO ═══ -->
      <section class="hsec" id="sec-historico">
        <h2 class="hsec-h">📈 Histórico (12h)</h2>
        <div class="legend"><span><span class="dot-s" style="background:var(--accent)"></span>Load</span><span><span class="dot-s" style="background:var(--blue)"></span>CPU %</span><span><span class="dot-s" style="background:var(--purple)"></span>RAM %</span></div>
        <div class="chart-wrap"><svg id="chart" viewBox="0 0 1000 320" style="width:100%;height:320px"></svg></div>
        <p style="color:var(--mut);font-size:.76rem;margin-top:.6rem" id="histInfo"></p>
      </section>

      <!-- ═══ SKILLS & MCP ═══ -->
      <section class="hsec" id="sec-skills">
        <h2 class="hsec-h">🔌 Skills & MCP <span class="tag" id="nbSkills">—</span></h2>
        <div class="box"><div class="box-h">🔌 MCPs configurados<span id="mcpSum"></span></div><table id="mcpT"><thead><tr><th>MCP</th><th>Tipo</th><th>Comando</th></tr></thead><tbody></tbody></table></div>
        <div class="box"><div class="box-h">⌨️ Comandos custom</div><table id="cmdT"><tbody></tbody></table></div>
        <div class="box-h" style="border:none;padding-left:0">⚡ Skills disponíveis <span id="skSum"></span></div>
        <input class="search" id="skSearch" placeholder="🔍 filtrar skills…" oninput="renderSkills()">
        <div class="p-grid tiles" id="skGrid"></div>
      </section>

      <!-- ═══ NOTAS ═══ -->
      <section class="hsec" id="sec-notas">
        <h2 class="hsec-h">📝 Memória — notas <span class="tag" id="nbNotes">—</span></h2>
        <p style="color:var(--mut);font-size:.84rem;margin-bottom:1rem">Notas do <a href="https://notas.bayerl.cloud" target="_blank" style="color:var(--accent)">SilverBullet</a> — clique pra abrir.</p>
        <div id="notesWrap"></div>
      </section>

      <!-- ═══ CLAUDE.md ═══ -->
      <section class="hsec" id="sec-claudemd">
        <h2 class="hsec-h">📄 CLAUDE.md (workspace)</h2>
        <div class="md" id="cmdMd">carregando…</div>
      </section>

    </div>
  </div>

  <!-- ── Documentação ── -->
  <div class="view" id="view-docs">
    <div class="topbar">
      <div>
        <div class="topbar-title" id="doc-title">Documentação</div>
        <div class="topbar-sub">conhecimento interno do Orion</div>
      </div>
    </div>
    <div class="p-content">

      <!-- VISÃO & ESTRATÉGIA -->
      <div class="doc-sec show" id="doc-s-visao">
        <div class="box">
          <div class="box-h">🔭 Visão</div>
          <p style="color:var(--txt);font-size:.9rem;line-height:1.7;margin-bottom:1.2rem">
            Orion é o orquestrador autônomo pessoal do Danilo. Um único cérebro que:
          </p>
          <ul style="color:var(--mut);font-size:.86rem;line-height:1.8;padding-left:1.2rem">
            <li>Recebe tarefas por <strong style="color:var(--txt)">qualquer canal</strong> — WhatsApp, plugin Claude Code, chat próprio</li>
            <li>Tem <strong style="color:var(--txt)">memória unificada</strong> — fala no WhatsApp, lembra no plugin. Zero diferença de canal.</li>
            <li>Delega código e infra via <strong style="color:var(--txt)">Delegate</strong> — sub-agentes que aparecem como sessões no plugin</li>
            <li>Cria <strong style="color:var(--txt)">cron jobs</strong> por linguagem natural</li>
            <li>Aprende continuamente: raw → episodic → semantic → skill → vault</li>
          </ul>
        </div>
        <div class="box">
          <div class="box-h">⚡ Princípio central</div>
          <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:1rem;margin-top:.5rem">
            <div style="background:#0d0d1a;border:1px solid #1e1e3a;border-radius:10px;padding:16px;text-align:center">
              <div style="font-size:1.8rem;margin-bottom:.4rem">🧠</div>
              <div style="color:var(--accent);font-weight:700;font-size:.85rem">Orion</div>
              <div style="color:var(--mut);font-size:.75rem;margin-top:.3rem">O cérebro — orquestra, decide, responde</div>
            </div>
            <div style="background:#0d0d1a;border:1px solid #1e1e3a;border-radius:10px;padding:16px;text-align:center">
              <div style="font-size:1.8rem;margin-bottom:.4rem">🤲</div>
              <div style="color:#f472b6;font-weight:700;font-size:.85rem">Claude Code Sessions</div>
              <div style="color:var(--mut);font-size:.75rem;margin-top:.3rem">As mãos — executa, coda, configura</div>
            </div>
            <div style="background:#0d0d1a;border:1px solid #1e1e3a;border-radius:10px;padding:16px;text-align:center">
              <div style="font-size:1.8rem;margin-bottom:.4rem">🗄️</div>
              <div style="color:#34d399;font-weight:700;font-size:.85rem">SQLite Unificado</div>
              <div style="color:var(--mut);font-size:.75rem;margin-top:.3rem">A memória — mesma para todos os canais</div>
            </div>
          </div>
        </div>
        <div class="box">
          <div class="box-h">📡 Canais</div>
          <table><thead><tr><th>Canal</th><th>Entrada</th><th>Contexto injetado</th><th>Sessão de ação</th></tr></thead><tbody>
            <tr><td>📱 WhatsApp</td><td>Evolution webhook</td><td>✅ pipeline completo</td><td>Registry → plugin sidebar</td></tr>
            <tr><td>💻 Plugin (aqui)</td><td>MCP orion_context</td><td>✅ mesmo pipeline</td><td>Sessão atual</td></tr>
            <tr><td>🌐 Chat UI</td><td>POST /api/chat</td><td>✅ mesmo pipeline</td><td>Registry → plugin sidebar</td></tr>
            <tr><td>⏰ Cron</td><td>node-cron</td><td>✅ mesmo pipeline</td><td>Nova sessão nomeada</td></tr>
          </tbody></table>
        </div>
      </div>

      <!-- FLUXO DE MEMÓRIA -->
      <div class="doc-sec" id="doc-s-memoria">

        <!-- ── VISÃO GERAL ── -->
        <div class="box">
          <div class="box-h">🧠 O que é o sistema de memória do Orion</div>
          <div style="padding:1rem 1.2rem;font-size:.84rem;color:var(--txt);line-height:1.8">
            <p>O Orion não tem uma memória — ele tem <strong>seis pipelines de memória paralelos</strong> que operam em camadas de tempo diferentes:</p>
            <ul style="margin:.6rem 0 1rem 1.4rem;color:var(--mut)">
              <li><strong style="color:var(--txt)">Instantâneo (por turno):</strong> extração por regex + Haiku + background review → banco SQLite</li>
              <li><strong style="color:var(--txt)">Curto prazo (30 min):</strong> Phase 2 — deduplicação BM25, decay de confiança, promoção raw→episodic</li>
              <li><strong style="color:var(--txt)">Médio prazo (6h):</strong> Phase 3 — merge semântico Haiku, contradições, escrita no vault</li>
              <li><strong style="color:var(--txt)">Diário (meia-noite):</strong> Phase 4 — arquivamento de memórias fracas, relatório WhatsApp</li>
              <li><strong style="color:var(--txt)">Semanal (domingos 9h):</strong> Phase 5 — self-audit Haiku: avalia qualidade das memórias mais usadas</li>
              <li><strong style="color:var(--txt)">Mensal (1º do mês):</strong> Phase 6 — ground-truth: verifica se fatos antigos ainda são verdade</li>
            </ul>
            <p style="color:var(--mut);font-size:.78rem">Cada memória tem: <code>type</code> · <code>category</code> · <code>confidence</code> · <code>source_channel</code> · <code>source_session_id</code> · <code>source_tool</code> · <code>helpful_votes</code> · <code>unhelpful_votes</code> · <code>access_count</code> · <code>tags</code> · vetor embedding 384 dims</p>
          </div>
        </div>

        <!-- ── PIPELINE POR TURNO ── -->
        <div class="box">
          <div class="box-h">⚡ Pipeline por turno — o que acontece após cada resposta</div>
          <div style="padding:1rem 1.2rem">
            <p style="font-size:.8rem;color:var(--mut);margin-bottom:1rem">Tudo abaixo roda em <code>setImmediate</code> (background, sem bloquear a resposta).</p>
            <div style="display:flex;flex-direction:column;gap:.5rem;max-width:700px">

              <div style="display:grid;grid-template-columns:160px 1fr;gap:.8rem;align-items:start">
                <div style="background:#0d1117;border:1px solid #1e3a1e;border-radius:8px;padding:8px 10px;text-align:center">
                  <div style="color:#34d399;font-size:.78rem;font-weight:700">extractFacts()</div>
                  <div style="color:#4b5563;font-size:.65rem;margin-top:.2rem">extraction.js</div>
                </div>
                <div style="font-size:.78rem;color:var(--mut);padding-top:.5rem">
                  <strong style="color:var(--txt)">Regex rápida, zero LLM.</strong> Detecta padrões como "meu projeto é X", "uso Y", nomes de pessoas, decisões explícitas. Salva como <code>type: raw</code>, <code>confidence: 0.5</code>. Roda em &lt;1ms.
                </div>
              </div>

              <div style="display:grid;grid-template-columns:160px 1fr;gap:.8rem;align-items:start">
                <div style="background:#0d1117;border:1px solid #1e1e3a;border-radius:8px;padding:8px 10px;text-align:center">
                  <div style="color:#818cf8;font-size:.78rem;font-weight:700">extractEntities()</div>
                  <div style="color:#4b5563;font-size:.65rem;margin-top:.2rem">extraction.js</div>
                </div>
                <div style="font-size:.78rem;color:var(--mut);padding-top:.5rem">
                  <strong style="color:var(--txt)">Knowledge graph leve.</strong> Extrai entidades (pessoas, projetos, ferramentas) e relações ("usa", "trabalha em", "prefere") → tabelas <code>entities</code> e <code>relations</code>. Também zero LLM.
                </div>
              </div>

              <div style="display:grid;grid-template-columns:160px 1fr;gap:.8rem;align-items:start">
                <div style="background:#0d1117;border:1px solid #2d1a00;border-radius:8px;padding:8px 10px;text-align:center">
                  <div style="color:#fb923c;font-size:.78rem;font-weight:700">extractWithHaiku()</div>
                  <div style="color:#4b5563;font-size:.65rem;margin-top:.2rem">memory/index.js · Haiku</div>
                </div>
                <div style="font-size:.78rem;color:var(--mut);padding-top:.5rem">
                  <strong style="color:var(--txt)">Extração semântica real.</strong> Haiku analisa a troca completa e retorna 0–3 fatos no formato <code>CATEGORIA|TAGS|fato</code>. Só roda se ambas as mensagens têm &gt;20 chars. Salva como <code>type: episodic</code>, <code>confidence: 0.65</code>, <code>sourceTool: haiku-extraction</code>.
                </div>
              </div>

              <div style="display:grid;grid-template-columns:160px 1fr;gap:.8rem;align-items:start">
                <div style="background:#0d1117;border:1px solid #1a1a2e;border-radius:8px;padding:8px 10px;text-align:center">
                  <div style="color:#a5b4fc;font-size:.78rem;font-weight:700">backgroundReview()</div>
                  <div style="color:#4b5563;font-size:.65rem;margin-top:.2rem">background-reviewer.js · Haiku</div>
                </div>
                <div style="font-size:.78rem;color:var(--mut);padding-top:.5rem">
                  <strong style="color:var(--txt)">Segundo olhar pós-turno.</strong> Haiku revisa a troca buscando o que a extração padrão pode ter perdido: fatos implícitos, candidatos a skill, hints de contradição. Retorna JSON <code>{ new_facts, skill_candidate, contradiction_hint }</code>. Salva com <code>sourceTool: background-review</code>, <code>confidence: 0.4</code> (mais conservador).
                </div>
              </div>

            </div>
          </div>
        </div>

        <!-- ── SCORE DE RETRIEVAL ── -->
        <div class="box">
          <div class="box-h">🎯 Como memórias são ranqueadas — fórmula de score</div>
          <div style="padding:1rem 1.2rem">
            <p style="font-size:.8rem;color:var(--mut);margin-bottom:.8rem">Quando o Orion busca memórias relevantes para uma mensagem, cada candidata recebe um score composto:</p>

            <div style="background:#0d0d1a;border:1px solid #1e1e3a;border-radius:10px;padding:1rem 1.2rem;font-family:monospace;font-size:.8rem;color:#e5e7eb;margin-bottom:1rem">
              score = 0.40 × BM25<span style="color:#818cf8">_norm</span><br>
              &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;+ 0.30 × vector<span style="color:#818cf8">_similarity</span><br>
              &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;+ 0.15 × confidence × <span style="color:#fb923c">decay</span>(category, age)<br>
              &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;+ 0.15 × recency<span style="color:#818cf8">_score</span>(created_at)<br>
              &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;+ <span style="color:#34d399">feedback_boost</span>(helpful_votes, unhelpful_votes)
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:.6rem">
              <div style="background:#0d1117;border:1px solid #1e1e3a;border-radius:8px;padding:.75rem 1rem">
                <div style="font-size:.78rem;font-weight:700;color:#818cf8;margin-bottom:.4rem">BM25 (0.40)</div>
                <div style="font-size:.72rem;color:var(--mut);line-height:1.5">Full-text search via FTS5. Normalizado: <code>|score| / (|score| + 1)</code>. Melhor para fatos explícitos mencionados na mensagem.</div>
              </div>
              <div style="background:#0d1117;border:1px solid #1e1e3a;border-radius:8px;padding:.75rem 1rem">
                <div style="font-size:.78rem;font-weight:700;color:#a5b4fc;margin-bottom:.4rem">Vector similarity (0.30)</div>
                <div style="font-size:.72rem;color:var(--mut);line-height:1.5">Cosseno no espaço <code>all-MiniLM-L6-v2</code> (384 dims, local). Melhor para conceitos relacionados mesmo sem palavras idênticas.</div>
              </div>
              <div style="background:#0d1117;border:1px solid #2d1a00;border-radius:8px;padding:.75rem 1rem">
                <div style="font-size:.78rem;font-weight:700;color:#fb923c;margin-bottom:.4rem">Decay adaptativo (0.15)</div>
                <div style="font-size:.72rem;color:var(--mut);line-height:1.5">
                  <code>conf × e^(−rate × age_days)</code><br>
                  Taxas por categoria:<br>
                  <span style="color:#e5e7eb">decision</span> 0.015 · <span style="color:#e5e7eb">tool</span> 0.008 · <span style="color:#e5e7eb">general</span> 0.005 · <span style="color:#e5e7eb">project</span> 0.003 · <span style="color:#e5e7eb">user_pref</span> 0.002 · <span style="color:#e5e7eb">person</span> 0.001
                </div>
              </div>
              <div style="background:#0d1117;border:1px solid #1e3a1e;border-radius:8px;padding:.75rem 1rem">
                <div style="font-size:.78rem;font-weight:700;color:#34d399;margin-bottom:.4rem">Recência (0.15)</div>
                <div style="font-size:.72rem;color:var(--mut);line-height:1.5"><code>e^(−λ × age_seconds)</code>. Decai ao longo de dias mas nunca zera. Garante que memórias recentes têm leve preferência.</div>
              </div>
              <div style="background:#0d1117;border:1px solid #1e3a1e;border-radius:8px;padding:.75rem 1rem;grid-column:span 2">
                <div style="font-size:.78rem;font-weight:700;color:#34d399;margin-bottom:.4rem">Feedback boost (±0.08)</div>
                <div style="font-size:.72rem;color:var(--mut);line-height:1.5">
                  <code>(hv − uv×2) / (hv + uv×2 + 1) × 0.08</code><br>
                  Assimétrico: voto negativo pesa 2× mais que positivo. Memórias com feedback ruim ficam para baixo. Memória com 1 positivo: +0.027. Com 1 negativo: −0.053. Sem votos: neutro.
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- ── CICLO DE VIDA DE UMA MEMÓRIA ── -->
        <div class="box">
          <div class="box-h">🔄 Ciclo de vida de uma memória — do raw ao archived</div>
          <div style="padding:1rem 1.2rem">
            <div style="display:flex;align-items:center;gap:0;flex-wrap:wrap;margin-bottom:1.2rem">
              <div style="background:#1a1a00;border:1px solid #2d2d00;border-radius:8px;padding:8px 14px;text-align:center">
                <div style="color:#fbbf24;font-size:.78rem;font-weight:700">raw</div>
                <div style="color:#6b7280;font-size:.62rem">conf 0.1–0.5</div>
              </div>
              <div style="color:#374151;padding:0 .4rem;font-size:1.1rem">→</div>
              <div style="background:#0d1117;border:1px solid #1e3a1e;border-radius:8px;padding:8px 14px;text-align:center">
                <div style="color:#34d399;font-size:.78rem;font-weight:700">episodic</div>
                <div style="color:#6b7280;font-size:.62rem">conf 0.5–0.7</div>
              </div>
              <div style="color:#374151;padding:0 .4rem;font-size:1.1rem">→</div>
              <div style="background:#0d0d1a;border:1px solid #2d1a3a;border-radius:8px;padding:8px 14px;text-align:center">
                <div style="color:#c084fc;font-size:.78rem;font-weight:700">semantic</div>
                <div style="color:#6b7280;font-size:.62rem">conf 0.7–0.9</div>
              </div>
              <div style="color:#374151;padding:0 .4rem;font-size:1.1rem">→</div>
              <div style="background:#0d0d1a;border:1px solid #1e1e3a;border-radius:8px;padding:8px 14px;text-align:center">
                <div style="color:#818cf8;font-size:.78rem;font-weight:700">skill</div>
                <div style="color:#6b7280;font-size:.62rem">conf &gt;0.85</div>
              </div>
              <div style="color:#374151;padding:0 .4rem;font-size:1.1rem">→</div>
              <div style="background:#1a0d0d;border:1px solid #3a1e1e;border-radius:8px;padding:8px 14px;text-align:center">
                <div style="color:#f87171;font-size:.78rem;font-weight:700">archived</div>
                <div style="color:#6b7280;font-size:.62rem">soft delete</div>
              </div>
            </div>

            <table><thead><tr><th>Fase</th><th>Frequência</th><th>O que faz</th><th>LLM?</th></tr></thead><tbody>
              <tr>
                <td><strong>Phase 2</strong></td><td>A cada 30 min</td>
                <td>
                  <strong>Deduplicação BM25:</strong> pairs de memórias similares → mantém a de maior confiança, arquiva a duplicata.<br>
                  <strong>Decay de confiança:</strong> aplica <code>conf × e^(−rate × age)</code> por categoria. Memórias que chegam a conf &lt; 0.05 são arquivadas.<br>
                  <strong>Promoção raw→episodic:</strong> memórias raw com conf ≥ 0.5 sobem de tipo.<br>
                  <strong>Contradiction detection:</strong> busca memórias com conteúdo oposto pelo mesmo sujeito → registra o par, reduz confiança da mais antiga.
                </td>
                <td style="color:var(--green)">Não</td>
              </tr>
              <tr>
                <td><strong>Phase 3</strong></td><td>A cada 6h</td>
                <td>
                  <strong>Merge de clusters:</strong> Haiku agrupa episodic similares em uma memória semantic mais rica.<br>
                  <strong>Promoção semantic→skill:</strong> patterns recorrentes viram skills reutilizáveis na tabela <code>skills</code>.<br>
                  <strong>Escrita no vault:</strong> insights consolidados são gravados em <code>notes/Orion/memoria/</code>.<br>
                  <code>sourceTool: phase3-merge</code>
                </td>
                <td style="color:#fb923c">Haiku</td>
              </tr>
              <tr>
                <td><strong>Phase 4</strong></td><td>Meia-noite</td>
                <td>
                  <strong>Arquivamento:</strong> memórias com confiança &lt; 0.05 ou sem acesso há 90+ dias → <code>archived = 1</code>.<br>
                  <strong>Relatório diário:</strong> envia resumo de memórias adicionadas hoje por WhatsApp.
                </td>
                <td style="color:#fb923c">Haiku</td>
              </tr>
              <tr>
                <td><strong>Phase 5</strong></td><td>Domingos 9h</td>
                <td>
                  <strong>Self-audit semanal:</strong> pega as top 20 memórias mais acessadas não auditadas nos últimos 30 dias.<br>
                  Haiku avalia cada uma de 1–5 (1=irrelevante, 5=fato preciso e útil).<br>
                  Score &lt; 2 → <code>confidence × 0.7</code> (punição). Salva <code>metadata.last_audit = { score, feedback, at }</code>.<br>
                  Envia resumo por WhatsApp: "X avaliadas, Y penalizadas".
                </td>
                <td style="color:#fb923c">Haiku</td>
              </tr>
              <tr>
                <td><strong>Phase 6</strong></td><td>1º do mês 9h</td>
                <td>
                  <strong>Ground-truth mensal:</strong> pega 10 memórias de categoria decision/person/project com confiança ≥ 0.5 não verificadas em 60+ dias.<br>
                  Haiku responde: "este fato ainda é verdade hoje?"<br>
                  Resposta "false" → <code>archived = 1</code> + <code>metadata.ground_truth = { reason, at }</code>.<br>
                  Resposta "true" → data de verificação atualizada, confiança preservada.
                </td>
                <td style="color:#fb923c">Haiku</td>
              </tr>
            </tbody></table>
          </div>
        </div>

        <!-- ── PROVENANCE ── -->
        <div class="box">
          <div class="box-h">🔍 Rastreabilidade — de onde veio cada memória</div>
          <div style="padding:1rem 1.2rem">
            <p style="font-size:.8rem;color:var(--mut);margin-bottom:.8rem">Cada memória tem 3 colunas de provenance além do campo <code>source</code> padrão:</p>
            <table><thead><tr><th>Campo</th><th>O que armazena</th><th>Exemplos</th></tr></thead><tbody>
              <tr><td><code>source_channel</code></td><td>Canal de origem da conversa</td><td><code>whatsapp</code> · <code>plugin</code> · <code>chat_ui</code></td></tr>
              <tr><td><code>source_session_id</code></td><td>UUID da sessão Claude Code ou WhatsApp</td><td><code>4e352b4b-8a74-...</code></td></tr>
              <tr><td><code>source_tool</code></td><td>Pipeline específico que criou a memória</td><td><code>haiku-extraction</code> · <code>background-review</code> · <code>pre-compress</code> · <code>delegate</code> · <code>phase3-merge</code> · <code>mcp-save</code></td></tr>
            </tbody></table>
          </div>
        </div>

        <!-- ── 4 MELHORIAS RECENTES ── -->
        <div class="box">
          <div class="box-h">🆕 4 melhorias recentes — paridade com Hermes + segurança</div>
          <div style="padding:1rem 1.2rem;display:flex;flex-direction:column;gap:1rem">

            <div style="background:#0d1117;border:1px solid #1e3a1e;border-radius:10px;padding:.9rem 1.1rem">
              <div style="display:flex;align-items:center;gap:.5rem;margin-bottom:.5rem">
                <span style="background:#14532d;color:#86efac;font-size:.65rem;font-weight:700;padding:2px 7px;border-radius:20px">A</span>
                <span style="font-size:.82rem;font-weight:700;color:#e5e7eb">on_pre_compress — extrai fatos antes de comprimir</span>
                <span style="font-size:.65rem;color:#4b5563;margin-left:auto">memory/compressor.js</span>
              </div>
              <p style="font-size:.78rem;color:var(--mut);line-height:1.6;margin:0">
                <strong style="color:var(--txt)">O problema:</strong> quando uma sessão com &gt;40 mensagens era comprimida, as mensagens descartadas iam para o lixo sem extração de fatos. Decisões tomadas, preferências mencionadas, projetos discutidos — tudo perdido.<br>
                <strong style="color:var(--txt)">A solução:</strong> <em>antes</em> do soft-delete, um Haiku analisa o transcript completo das mensagens a serem descartadas e extrai até 5 fatos no formato <code>CATEGORIA|TAGS|fato</code>. Salvos com <code>sourceTool: pre-compress</code>. Roda em <code>setImmediate</code>, não atrasa a resposta.
              </p>
            </div>

            <div style="background:#0d0d1a;border:1px solid #1e1e3a;border-radius:10px;padding:.9rem 1.1rem">
              <div style="display:flex;align-items:center;gap:.5rem;margin-bottom:.5rem">
                <span style="background:#312e81;color:#a5b4fc;font-size:.65rem;font-weight:700;padding:2px 7px;border-radius:20px">B</span>
                <span style="font-size:.82rem;font-weight:700;color:#e5e7eb">on_delegation — captura resultado do subagente</span>
                <span style="font-size:.65rem;color:#4b5563;margin-left:auto">agent/delegate.js</span>
              </div>
              <p style="font-size:.78rem;color:var(--mut);line-height:1.6;margin:0">
                <strong style="color:var(--txt)">O problema:</strong> quando o Orion delegava uma tarefa (ex: "analisa o Brandspace"), o subagente executava, produzia output — e esse output nunca entrava na memória. Na próxima sessão, o Orion não lembrava o que tinha feito.<br>
                <strong style="color:var(--txt)">A solução:</strong> após cada delegação bem-sucedida, salva automaticamente: <code>"Tarefa delegada (role): [goal] → [snippet do resultado]"</code>. Tags incluem <code>delegate</code>, o role e o projeto. Categoria <code>decision</code>.
              </p>
            </div>

            <div style="background:#0d1117;border:1px solid #1e2e1e;border-radius:10px;padding:.9rem 1.1rem">
              <div style="display:flex;align-items:center;gap:.5rem;margin-bottom:.5rem">
                <span style="background:#14532d;color:#86efac;font-size:.65rem;font-weight:700;padding:2px 7px;border-radius:20px">C</span>
                <span style="font-size:.82rem;font-weight:700;color:#e5e7eb">Feedback no score de retrieval</span>
                <span style="font-size:.65rem;color:#4b5563;margin-left:auto">memory/index.js</span>
              </div>
              <p style="font-size:.78rem;color:var(--mut);line-height:1.6;margin:0">
                <strong style="color:var(--txt)">O problema:</strong> os campos <code>helpful_votes</code> e <code>unhelpful_votes</code> existiam no banco mas eram ignorados no ranking. Feedback do usuário não tinha impacto nenhum.<br>
                <strong style="color:var(--txt)">A solução:</strong> o score agora inclui <code>feedback_boost = (hv − uv×2) / (hv + uv×2 + 1) × 0.08</code>. Assimétrico: voto negativo penaliza 2× mais que positivo recompensa. Memórias marcadas como inúteis afundam no ranking progressivamente.
              </p>
            </div>

            <div style="background:#1a0d0d;border:1px solid #3a1e1e;border-radius:10px;padding:.9rem 1.1rem">
              <div style="display:flex;align-items:center;gap:.5rem;margin-bottom:.5rem">
                <span style="background:#7f1d1d;color:#fca5a5;font-size:.65rem;font-weight:700;padding:2px 7px;border-radius:20px">D</span>
                <span style="font-size:.82rem;font-weight:700;color:#e5e7eb">Threat detection — anti injeção de prompt</span>
                <span style="font-size:.65rem;color:#4b5563;margin-left:auto">memory/threat-check.js</span>
              </div>
              <p style="font-size:.78rem;color:var(--mut);line-height:1.6;margin:0">
                <strong style="color:var(--txt)">O problema:</strong> qualquer mensagem enviada pelo WhatsApp podia conter injeção de prompt que seria persistida no banco e servida como contexto em todas as respostas futuras.<br>
                <strong style="color:var(--txt)">A solução:</strong> antes de qualquer <code>saveMemory()</code>, o conteúdo passa por <code>threatCheck()</code> com 16 regex patterns (ignore instructions, you are now, reveal system prompt, eval/exec, etc). Se match: salva com <code>confidence: 0.01</code> e tags <code>["blocked","threat"]</code> — preservado para auditoria, mas nunca surfaceado no retrieval.
              </p>
            </div>

          </div>
        </div>

        <!-- ── RETRIEVAL HRR ── -->
        <div class="box">
          <div class="box-h">🔮 HRR Composer — multi-entity queries algébricas</div>
          <div style="padding:1rem 1.2rem">
            <p style="font-size:.8rem;color:var(--mut);margin-bottom:.8rem">Quando você quer memórias que envolvem <em>múltiplas entidades ao mesmo tempo</em> (ex: "o que sei sobre Danilo E Orion"), o BM25 padrão faz duas buscas separadas. O HRR Composer combina as entidades em um único vetor de consulta via álgebra de espaço de fases:</p>
            <div style="background:#0d0d1a;border:1px solid #1e1e3a;border-radius:8px;padding:.75rem 1rem;font-family:monospace;font-size:.78rem;color:#e5e7eb;margin-bottom:.8rem">
              normalize(v) → ||v|| = 1, Float32Array<br>
              bindVectors(a, b) → produto Hadamard + normalize<br>
              superpose([v1, v2, ...]) → soma ponderada + normalize<br>
              <br>
              retrieveByComposedEntities(["Danilo", "Orion"], limit=10)<br>
              &nbsp;&nbsp;→ embedding("Danilo") + embedding("Orion")<br>
              &nbsp;&nbsp;→ superpose → KNN search no vec_memories
            </div>
            <p style="font-size:.78rem;color:var(--mut)">Endpoint: <code>GET /api/memories/entities-composed?names=A,B&limit=10</code></p>
          </div>
        </div>

        <!-- ── SEGURANÇA ── -->
        <div class="box">
          <div class="box-h">📊 Pipeline de Contexto — o que é injetado antes de cada resposta</div>
          <p style="color:var(--mut);font-size:.8rem;margin:.8rem 1.2rem .4rem">Montado por <code>buildFullContext()</code> em src/api/context.js — todas as camadas em paralelo.</p>
          <div style="padding:.2rem 1.2rem 1rem">
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:.6rem">
              <div class="flow-layer" style="border-color:#818cf8"><div class="flow-layer-num">1</div><div><div class="flow-layer-title">user_profile.md</div><div class="flow-layer-sub">identidade, projetos, preferências do Danilo — atualizado por Haiku pós-turno</div><div class="flow-layer-tag">data/user_profile.md</div></div></div>
              <div class="flow-layer" style="border-color:#f472b6"><div class="flow-layer-num">2</div><div><div class="flow-layer-title">CLAUDE.md do projeto</div><div class="flow-layer-sub">regras técnicas — detectado automaticamente pelo slug na mensagem</div><div class="flow-layer-tag">brandspace/CLAUDE.md etc.</div></div></div>
              <div class="flow-layer" style="border-color:#34d399"><div class="flow-layer-num">3</div><div><div class="flow-layer-title">Vault Global</div><div class="flow-layer-sub">Padrões de Qualidade + Stack Técnica — sempre, em todo projeto</div><div class="flow-layer-tag">notes/Global/*.md</div></div></div>
              <div class="flow-layer" style="border-color:#34d399"><div class="flow-layer-num">4</div><div><div class="flow-layer-title">Vault do Projeto</div><div class="flow-layer-sub">todas as notas da pasta — garantido, sem ranking</div><div class="flow-layer-tag">notes/Brandspace/*.md etc.</div></div></div>
              <div class="flow-layer" style="border-color:#fb923c"><div class="flow-layer-num">5</div><div><div class="flow-layer-title">Memories híbridas</div><div class="flow-layer-sub">BM25 + vetor + decay + feedback → top-8 mais relevantes</div><div class="flow-layer-tag">SQLite · memories_fts + vec_memories</div></div></div>
              <div class="flow-layer" style="border-color:#c084fc"><div class="flow-layer-num">6</div><div><div class="flow-layer-title">Skills relevantes</div><div class="flow-layer-sub">padrões reutilizáveis aprendidos — buscados por LIKE na query</div><div class="flow-layer-tag">SQLite · skills</div></div></div>
            </div>
            <div style="background:#0d1117;border:1px solid #1e1e3a;border-radius:8px;padding:.65rem .9rem;margin-top:.6rem;font-size:.75rem;color:#6b7280">
              ⚠️ <strong style="color:#9ca3af">Invariante crítico:</strong> memória é sempre injetada na <em>mensagem do usuário</em> (via tag <code>&lt;memory&gt;</code>), NUNCA no system prompt. Isso preserva o prefix cache da Anthropic — respostas mais rápidas e baratas.
            </div>
          </div>
        </div>

        <div class="box">
          <div class="box-h">📦 Fontes do banco de memórias</div>
          <table id="mem-sources-table"><thead><tr><th>Fonte</th><th>Chunks</th><th>Atualização</th><th>O que contém</th></tr></thead>
          <tbody>
            <tr><td><span style="color:#34d399">vault</span></td><td id="ms-vault">—</td><td>A cada hora (cron)</td><td>Notas do SilverBullet</td></tr>
            <tr><td><span style="color:#818cf8">claude_md</span></td><td id="ms-claudemd">—</td><td>A cada hora (cron)</td><td>CLAUDE.md global + regras</td></tr>
            <tr><td><span style="color:#f472b6">claude_mem</span></td><td id="ms-claudemem">—</td><td>A cada hora (cron)</td><td>memory/*.md desta sessão</td></tr>
            <tr><td><span style="color:#fb923c">whatsapp</span></td><td id="ms-whatsapp">—</td><td>Por turno</td><td>Fatos extraídos das conversas</td></tr>
          </tbody></table>
        </div>
      </div>

      <!-- ARQUITETURA -->
      <div class="doc-sec" id="doc-s-arquitetura">
        <div class="box">
          <div class="box-h">🏗️ Módulos do Orion</div>
          <table><thead><tr><th>Módulo</th><th>Arquivo</th><th>Função</th></tr></thead><tbody>
            <tr><td><code>orion.js</code></td><td>src/agent/</td><td>Loop principal — recebe mensagem, monta contexto, chama Claude, salva resposta</td></tr>
            <tr><td><code>context.js</code></td><td>src/api/</td><td>Pipeline unificado — monta todas as 6 camadas de contexto</td></tr>
            <tr><td><code>delegate.js</code></td><td>src/agent/</td><td>Delegate tool — cria sessões nomeadas visíveis no plugin para subtarefas</td></tr>
            <tr><td><code>orchestrator.js</code></td><td>src/agent/</td><td>Planner → workers paralelos → synthesizer (via /multi)</td></tr>
            <tr><td><code>registry.js</code></td><td>src/sessions/</td><td>Sessões nomeadas persistidas — garante continuidade entre conversas</td></tr>
            <tr><td><code>memory/index.js</code></td><td>src/memory/</td><td>BM25 + vetor — busca híbrida de memórias</td></tr>
            <tr><td><code>compressor.js</code></td><td>src/memory/</td><td>Turn protection — comprime histórico longo, preserva início e fim</td></tr>
            <tr><td><code>skill-generator.js</code></td><td>src/agent/</td><td>Gera skills automáticas por turno via Haiku</td></tr>
            <tr><td><code>user-profile.js</code></td><td>src/agent/</td><td>Perfil persistente do Danilo — atualizado em background</td></tr>
            <tr><td><code>memory-server.js</code></td><td>src/mcp/</td><td>MCP stdio — orion_memory_context, orion_context, orion_delegate</td></tr>
            <tr><td><code>ingest_knowledge.py</code></td><td>scripts/</td><td>Vault + CLAUDE.md → SQLite (roda a cada hora)</td></tr>
          </tbody></table>
        </div>
        <div class="box">
          <div class="box-h">🔄 Fases de memória (consolidação contínua)</div>
          <table><thead><tr><th>Fase</th><th>Frequência</th><th>O que faz</th><th>LLM</th></tr></thead><tbody>
            <tr><td><span style="color:#fb923c">Fase 1</span></td><td>Por turno</td><td>Extrai fatos, entidades, relações das conversas</td><td>Não</td></tr>
            <tr><td><span style="color:#f472b6">Fase 2</span></td><td>30 min</td><td>Dedup BM25 · decay · raw→episodic · arquiva obsoletos</td><td>Não</td></tr>
            <tr><td><span style="color:#818cf8">Fase 3</span></td><td>6 horas</td><td>Haiku mescla clusters · contradições · skills → vault</td><td>Haiku</td></tr>
            <tr><td><span style="color:#34d399">Fase 4</span></td><td>Diária</td><td>Arquivo 90d · relatório WhatsApp</td><td>Não</td></tr>
            <tr><td><span style="color:#c084fc">Knowledge</span></td><td>1 hora</td><td>Vault + CLAUDE.md + memory/ → SQLite (349 chunks)</td><td>Não</td></tr>
          </tbody></table>
        </div>
        <div class="box">
          <div class="box-h">🔌 Delegate — roles e ferramentas</div>
          <table><thead><tr><th>Role</th><th>Ferramentas</th><th>Uso típico</th></tr></thead><tbody>
            <tr><td><code>researcher</code></td><td>Read, Grep, Glob, WebFetch, WebSearch</td><td>Busca informações, lê documentação</td></tr>
            <tr><td><code>coder</code></td><td>Read, Grep, Glob, Edit, Write, Bash</td><td>Escreve e modifica código</td></tr>
            <tr><td><code>analyst</code></td><td>Read, Grep, Glob</td><td>Analisa código e dados</td></tr>
            <tr><td><code>writer</code></td><td>Read, Write</td><td>Documenta, redige conteúdo</td></tr>
            <tr><td><code>executor</code></td><td>* (all)</td><td>Tarefas completas de infra e deploy</td></tr>
          </tbody></table>
        </div>
      </div>

      <!-- CLAUDE.MD FILES -->
