</main>

<div id="toast"></div>

<script>
// ── Navigation ────────────────────────────────────────────────────────────────
const panelViews = ['p-geral','p-projetos','p-memoria','p-cerebro','p-claudemd','p-dns','p-whatsapp','p-bancos','p-historico']
const panelTitles = {
  'p-geral':'Visão Geral','p-projetos':'Projetos','p-memoria':'Memória (notas)',
  'p-cerebro':'Skills & MCP','p-claudemd':'CLAUDE.md','p-dns':'DNS & Domínios',
  'p-whatsapp':'WhatsApp','p-bancos':'Bancos de dados','p-historico':'Histórico (12h)'
}
const panelSections = {'p-geral':'geral','p-projetos':'projetos','p-memoria':'memoria','p-cerebro':'cerebro','p-claudemd':'claudemd','p-dns':'dns','p-whatsapp':'whatsapp','p-bancos':'bancos','p-historico':'historico'}

let panelLoaded = false

const docViews = ['doc-visao','doc-memoria','doc-arquitetura','doc-claudemds','doc-progresso']
const docTitles = { 'doc-visao':'Visão & Estratégia','doc-memoria':'Fluxo de Memória','doc-arquitetura':'Arquitetura','doc-claudemds':'CLAUDE.md — Hierarquia','doc-progresso':'Progresso do Build' }

// Mapa de deep-links de servidor (/d/p-*) → seção da home unificada (compat com bookmarks)
const SEC_OF = { 'p-geral':'sec-servidor','p-projetos':'sec-projetos','p-memoria':'sec-notas','p-cerebro':'sec-skills','p-claudemd':'sec-claudemd','p-dns':'sec-dns','p-whatsapp':'sec-whatsapp','p-bancos':'sec-bancos','p-historico':'sec-historico' }
function goSec(id){ const el=document.getElementById(id); if(el) el.scrollIntoView({behavior:'smooth',block:'start'}) }

// Ativa uma view. push=true grava no histórico para F5/deep-link funcionarem.
function activateView(view, push = true) {
  const isDoc = docViews.includes(view)
  const isHome = view === 'orion-dash' || panelViews.includes(view)
  if (!isHome && !isDoc) view = 'orion-dash'

  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'))
  const btn = document.querySelector(`.nav-item[data-view="${view}"]`)
  if (btn) btn.classList.add('active')

  if (isDoc) {
    document.getElementById('view-orion-dash').classList.remove('active')
    document.getElementById('view-docs').classList.add('active')
    document.querySelectorAll('.doc-sec').forEach(s => s.classList.remove('show'))
    const ds = document.getElementById('doc-s-' + view.replace('doc-', '')); if (ds) ds.classList.add('show')
    document.getElementById('doc-title').textContent = docTitles[view] || 'Documentação'
  } else {
    document.getElementById('view-docs').classList.remove('active')
    document.getElementById('view-orion-dash').classList.add('active')
    const homeBtn = document.querySelector('.nav-item[data-view="orion-dash"]'); if (homeBtn) homeBtn.classList.add('active')
    // deep-link de servidor → rola até a seção correspondente
    if (panelViews.includes(view)) { const sec = SEC_OF[view]; if (sec) setTimeout(() => goSec(sec), 80) }
  }

  if (push) {
    try { history.pushState({ view }, '', view === 'orion-dash' ? '/' : '/d/' + view) } catch {}
  }
}

document.querySelectorAll('.nav-item[data-view]').forEach(btn => {
  btn.addEventListener('click', () => activateView(btn.dataset.view, true))
})

// Deep-linking: lê /d/<view> da URL no load e em back/forward (F5 não volta pra home)
function viewFromPath() {
  const m = location.pathname.match(/^\/d\/([\w-]+)/)
  return m ? m[1] : 'orion-dash'
}
activateView(viewFromPath(), false)
window.addEventListener('popstate', () => activateView(viewFromPath(), false))

// ── Orion Dashboard ───────────────────────────────────────────────────────────
const fmt = ts => new Date(ts * 1000).toLocaleTimeString('pt-BR', { hour:'2-digit', minute:'2-digit' })

async function loadOrionStats() {
  try {
    const [mRes, sRes, msgRes, cronRes, csRes] = await Promise.all([
      fetch('/api/memories?limit=5'), fetch('/api/sessions'),
      fetch('/api/messages?limit=8'), fetch('/api/cron'),
      fetch('/api/claude-sessions?limit=1'),
    ])
    const [mData, sData, msgData, cronData, csData] = await Promise.all([
      mRes.json(), sRes.json(), msgRes.json(), cronRes.json(), csRes.json()
    ])
    document.getElementById('mem-count').textContent  = mData.total ?? mData.memories?.length ?? '—'
    const types = {}; mData.memories?.forEach(m => types[m.type] = (types[m.type]||0)+1)
    document.getElementById('mem-types').textContent = Object.entries(types).map(([k,v])=>`${v} ${k}`).join(' · ') || 'nenhuma'
    document.getElementById('sess-count').textContent = sData.sessions?.length ?? '—'
    document.getElementById('msg-count').textContent  = msgData.total ?? msgData.messages?.length ?? '—'
    document.getElementById('cron-count').textContent = cronData.jobs?.length ?? '—'
    document.getElementById('sessions-badge').textContent = csData.sessions?.length ?? '—'
    const msgs = msgData.messages ?? []
    const list = document.getElementById('msg-list')
    list.innerHTML = msgs.length
      ? msgs.map(m => `<div class="msg"><span class="msg-role ${m.role}">${m.role}</span><span class="msg-content">${(m.content||'').slice(0,120)}${(m.content||'').length>120?'…':''}</span><span class="msg-time">${fmt(m.created_at)}</span></div>`).join('')
      : '<div class="empty">Nenhuma mensagem ainda</div>'
  } catch(e) { console.error(e) }
}

async function checkWa() {
  try {
    const d = await fetch('/api/wa/status').then(r=>r.json())
    const dot=document.getElementById('wa-dot'), dotS=document.getElementById('wa-dot-side')
    const txt=document.getElementById('wa-status-text'), txtS=document.getElementById('wa-status-side')
    const badge=document.getElementById('wa-badge'), qrCtr=document.getElementById('qr-container')
    if (d.status === 'open') {
      dot.className = dotS.className = 'status-dot'
      txt.textContent = txtS.textContent = 'Conectado'
      badge.className = 'badge-pill online'; badge.textContent = 'online'
      qrCtr.style.display = 'none'
    } else if (d.qr) {
      dot.className = dotS.className = 'dot yellow'
      txt.textContent = txtS.textContent = 'Aguardando QR'
      badge.className = 'badge-pill connecting'; badge.textContent = 'conectando'
      qrCtr.style.display = 'block'
      document.getElementById('qr-img').src = d.qr
      setTimeout(checkWa, 5000)
    } else {
      dot.className = 'dot red'; dotS.className = 'status-dot' // keep dot styled differently in sidebar
      txt.textContent = txtS.textContent = 'Desconectado'
      badge.className = 'badge-pill offline'; badge.textContent = 'offline'
      qrCtr.style.display = 'none'
      setTimeout(checkWa, 8000)
    }
  } catch { setTimeout(checkWa, 8000) }
}

document.getElementById('uptime').textContent = new Date().toLocaleDateString('pt-BR', {weekday:'long', day:'2-digit', month:'long'})

// ── SALIM: monitor de tokens Claude ──────────────────────────────────────────
function fmtReset(iso) {
  if (!iso) return ''
  const d = new Date(iso), now = Date.now()
  const diff = d - now
  if (diff <= 0) return 'resetou'
  const h = Math.floor(diff / 3600000), m = Math.floor((diff % 3600000) / 60000)
  return h > 0 ? `reset em ${h}h${m.toString().padStart(2,'0')}m` : `reset em ${m}m`
}
function usageColor(pct) {
  if (pct >= 85) return '#f87171' // vermelho
  if (pct >= 60) return '#fbbf24' // amarelo
  return '#6366f1'               // roxo (accent)
}
async function loadSalim() {
  try {
    const d = await fetch('/api/claude-usage').then(r => r.json())
    if (!d || d.error) return
    const grp = document.getElementById('salim-group')
    if (grp) grp.style.display = 'flex'
    const sess = d.session, week = d.week
    if (sess) {
      document.getElementById('salim-sess-fill').style.cssText = `width:${sess.pct}%;background:${usageColor(sess.pct)}`
      document.getElementById('salim-sess-pct').textContent = sess.pct + '%'
      document.getElementById('salim-sess-reset').textContent = fmtReset(sess.resets_at)
    }
    if (week) {
      document.getElementById('salim-week-fill').style.cssText = `width:${week.pct}%;background:${usageColor(week.pct)}`
      document.getElementById('salim-week-pct').textContent = week.pct + '%'
      document.getElementById('salim-week-reset').textContent = fmtReset(week.resets_at)
    }
  } catch {}
}
loadSalim()
setInterval(loadSalim, 60000)

loadOrionStats()
checkWa()
setInterval(loadOrionStats, 15000)

// ── Panel JS ──────────────────────────────────────────────────────────────────
const $p=s=>document.querySelector(s), $$p=s=>document.querySelectorAll(s)
const cls=(v,g,y)=>v<g?'var(--green)':v<y?'var(--yellow)':'var(--red)'
let STATS={}, KNOW={}, HIST=[]

function pcard(l,v,sub,pct,color){return `<div class="p-card"><div class="l">${l}</div><div class="v">${v}</div>${pct!=null?`<div class="pbar"><i style="width:${Math.min(pct,100)}%;background:${color}"></i></div>`:''}<div class="sub">${sub}</div></div>`}

function renderStats(){
  const d=STATS; if(!d.vps)return; const v=d.vps, cores=v.cpu_cores
  $p('#bHost') && ($p('#bHost').textContent=v.hostname)
  $p('#sideFoot') && ($p('#sideFoot').innerHTML=`🟢 ${v.hostname} · ${v.public_ip}<br>uptime ${v.uptime_hours}h${v.uptime_minutes}m`)
  $p('#hUpdated').textContent=d.updated_local
  const sw=v.swap||{percent:0,used_mb:0,total_mb:0}
  $p('#ovCards').innerHTML=
    pcard('CPU',v.cpu_usage+'%','uso atual',v.cpu_usage,cls(v.cpu_usage,60,85))+
    pcard('Memória',v.memory.percent+'%',`${(v.memory.used_mb/1024).toFixed(1)}/${(v.memory.total_mb/1024).toFixed(1)} GB`,v.memory.percent,cls(v.memory.percent,75,90))+
    pcard('Swap',sw.percent+'%',`${(sw.used_mb/1024).toFixed(1)}/${(sw.total_mb/1024).toFixed(0)} GB`,sw.percent,cls(sw.percent,80,95))+
    pcard('Disco',v.disk.percent+'%',`${v.disk.used}/${v.disk.total} · ${v.disk.free} livre`,v.disk.percent,cls(v.disk.percent,75,90))+
    pcard('Containers',d.docker.running,`${d.claude.sessions} Claude · ${d.claude.mcp_procs} MCPs`,null)+
    pcard('CPU cores',cores,'núcleos',null)
  const msgs=[]; if(v.memory.percent>90)msgs.push('RAM em '+v.memory.percent+'%')
  if(sw.percent>85)msgs.push('swap em '+sw.percent+'%')
  if(parseFloat(v.load_avg['1m'])>cores)msgs.push('load '+v.load_avg['1m']+' acima dos '+cores+' núcleos')
  const ab=$p('#alertBar'); if(msgs.length){ab.classList.add('show');ab.innerHTML='⚠️ '+msgs.join(' · ')}else ab.classList.remove('show')
  const g=cores*.7, lc=x=>cls(parseFloat(x),g,cores)
  $p('#ovLoads').innerHTML=[['1 min',v.load_avg['1m']],['5 min',v.load_avg['5m']],['15 min',v.load_avg['15m']]].map(([k,x])=>`<div class="lc"><div class="l">Load — ${k}</div><div class="n" style="color:${lc(x)}">${x}</div></div>`).join('')
  $p('#procT tbody').innerHTML=(d.top_proc||[]).slice().sort((a,b)=>(b.cpu||0)-(a.cpu||0)).map(p=>`<tr><td class="mono">${p.cmd}</td><td style="color:${cls(p.cpu,30,70)};font-weight:700">${p.cpu}%</td><td>${p.mem}%</td></tr>`).join('')
  $p('#ramT tbody') && ($p('#ramT tbody').innerHTML=(d.top_ram||[]).map(p=>`<tr><td class="mono">${p.cmd}</td><td style="font-weight:700;color:${cls(p.ram_mb,1000,2500)}">${p.ram_mb>=1024?(p.ram_mb/1024).toFixed(1)+' GB':p.ram_mb+' MB'}</td><td>${p.cpu}%</td></tr>`).join(''))
  const ic={'code-server':'💻','SilverBullet':'📓','n8n':'🔀','Evolution API':'💬','Landing pages':'🌍','Orion':'⚡'}
  $p('#ovSvc').innerHTML=(d.services||[]).slice().sort((a,b)=>((a.status==='online')?0:1)-((b.status==='online')?0:1)).map(s=>`<a class="tile" href="${s.url}" target="_blank"><div class="t">${ic[s.name]||'🔗'} ${s.name} <span class="dot-s" style="background:${s.status==='online'?'var(--green)':'var(--red)'};width:8px;height:8px;border-radius:50%;margin-left:auto;display:inline-block"></span></div><div class="d">${s.desc}</div></a>`).join('')
  const ctrs=(d.docker?.containers||[]).slice().sort((a,b)=>(b.cpu||0)-(a.cpu||0) || (b.mem_mb||0)-(a.mem_mb||0))
  const memMax=Math.max(...ctrs.map(c=>c.mem_mb||0),1)
  const cpuMax=Math.max(...ctrs.map(c=>c.cpu||0),1)
  $p('#containerGrid').innerHTML=ctrs.map(c=>{
    const nm=c.name.replace(/^stack-/,'').replace(/-1$/,'')
    const up=c.status&&c.status.toLowerCase().startsWith('up')
    const dotC=up?'var(--green)':'var(--red)'
    const cpuPct=Math.min((c.cpu||0)/Math.max(cpuMax,100)*100,100)
    const memPct=Math.min((c.mem_mb||0)/memMax*100,100)
    const memStr=c.mem_mb>=1024?((c.mem_mb/1024).toFixed(1)+' GB'):(c.mem_mb+' MB')
    const cpuColor=cls(c.cpu,30,100)
    const memColor=cls(c.mem_pct||0,50,80)
    const imgShort=c.image.split('/').pop().split(':')[0]
    return `<div class="ct-card">
      <div class="ct-head">
        <span class="ct-dot" style="background:${dotC}"></span>
        <span class="ct-name" title="${c.name}">${nm}</span>
        <span class="ct-img" title="${c.image}">${imgShort}</span>
      </div>
      <div class="ct-row">
        <span class="ct-label">CPU</span>
        <div class="ct-bar"><i style="width:${cpuPct.toFixed(1)}%;background:${cpuColor}"></i></div>
        <span class="ct-val" style="color:${cpuColor}">${c.cpu}%</span>
      </div>
      <div class="ct-row">
        <span class="ct-label">RAM</span>
        <div class="ct-bar"><i style="width:${memPct.toFixed(1)}%;background:${memColor}"></i></div>
        <span class="ct-val" style="color:${memColor}">${memStr}</span>
      </div>
    </div>`}).join('')||'<p style="color:var(--mut);font-size:.8rem">sem dados de containers</p>'
  const ds=(d.dev_servers||[]).slice().sort((a,b)=>(b.cpu||0)-(a.cpu||0) || (b.mem||0)-(a.mem||0))
  $p('#devSum').textContent=ds.filter(p=>p.status==='online').length+'/'+ds.length+' on'
  $p('#nbProj').textContent=ds.length
  $p('#devT tbody').innerHTML=ds.map(p=>{const on=p.status==='online';
    return `<tr><td><b>${p.name}</b></td><td><span class="pill ${on?'on':'stop'}">${p.status}</span></td><td>${p.mem} MB</td><td>${p.cpu}%</td>
    <td class="row">${on?`<button class="btn r" onclick="act('pm2_stop',{name:'${p.name}'},this)">parar</button><button class="btn" onclick="act('pm2_restart',{name:'${p.name}'},this)">restart</button>`:`<button class="btn g" onclick="act('pm2_start',{name:'${p.name}'},this)">ligar</button>`}</td></tr>`}).join('')||'<tr><td colspan=5 style="color:var(--mut)">nenhum dev server</td></tr>'
}

function renderKnow(){
  const k=KNOW
  const ck=(ok,l)=>`<span class="ck ${ok?'on':'off'}">${ok?'✓':'✗'} ${l}</span>`
  const tax=k.taxonomy||{projects:[],tools:[]}
  $p('#projWrap').innerHTML=(tax.projects||[]).map(p=>{
    const items=[['Supabase MCP',p.supabase_mcp],['Cloudflare (token)',p.cloudflare_token],['.env',p.env],['Git',p.git]]
    const done=items.filter(i=>i[1]).length, full=done===items.length
    return `<div class="proj"><div class="proj-h"><b>${p.label}</b>${p.code?'<span class="chip">node</span>':''}<span class="chip">${p.size}</span>${p.branch?`<span class="chip">⎇ ${p.branch}</span>`:''}<span style="margin-left:auto">${full?'<span class="b100">100% ✓</span>':`<span class="bpend">${done}/${items.length}</span>`}</span></div>
      <div class="checklist">${items.map(i=>ck(i[1],i[0])).join('')}</div><div class="proj-sub">${p.commit||'—'}</div>
      ${(p.tools&&p.tools.length)?`<div class="nest">🔧 ${p.tools.map(t=>`<b>${t.id}</b> <span style="opacity:.6">(${t.size})</span>`).join(' · ')}</div>`:''}</div>`
  }).join('')||'<p style="color:var(--mut)">—</p>'
  $p('#toolsWrap').innerHTML=(tax.tools||[]).map(t=>`<div class="tile"><div class="t">🔧 ${t.id}</div><div class="d">${t.exists?t.size:'—'}${t.git?' · git':''}${t.code?' · node':''}</div></div>`).join('')
  $p('#nbNotes').textContent=(k.notes||[]).length
  const byF={}; (k.notes||[]).forEach(n=>{(byF[n.folder]=byF[n.folder]||[]).push(n)})
  $p('#notesWrap').innerHTML=Object.entries(byF).map(([f,ns])=>`<div class="box"><div class="box-h">📁 ${f} <span>${ns.length}</span></div><table><tbody>${ns.map(n=>`<tr><td style="width:200px"><a href="${n.url}" target="_blank" style="color:var(--blue);font-weight:600">📝 ${n.name}</a></td><td style="color:var(--mut);font-size:.8rem">${(n.excerpt||'').replace(/\n/g,' ')}</td></tr>`).join('')}</tbody></table></div>`).join('')
  $p('#mcpSum').textContent=(k.mcps||[]).length
  $p('#mcpT tbody').innerHTML=(k.mcps||[]).map(m=>`<tr><td><b>${m.name}</b></td><td><span class="chip">${m.type}</span></td><td class="mono" style="color:var(--mut)">${m.cmd}</td></tr>`).join('')
  $p('#cmdT tbody').innerHTML=(k.commands||[]).map(c=>`<tr><td class="mono" style="color:var(--accent);width:200px">${c.name}</td><td style="color:var(--mut);font-size:.82rem">${c.desc||''}</td></tr>`).join('')
  $p('#nbSkills').textContent=(k.skills||[]).length
  $p('#skSum').textContent='('+(k.skills||[]).length+')'
  renderSkills()
  $p('#cmdMd').innerHTML=mdRender(k.claude_md||'(vazio)')
  $p('#nbDns').textContent=(k.dns||[]).length
  const cont=(k.dns||[]).filter(r=>r.target==='contabo').length, host=(k.dns||[]).filter(r=>r.target==='hostinger').length
  $p('#dnsCards').innerHTML=pcard('🟢 No Contabo',cont,'subdomínios ativos',null)+pcard('🟠 No Hostinger',host,'legado',null)+pcard('Outros',(k.dns||[]).length-cont-host,'externos',null)
  const tc={contabo:'var(--green)',hostinger:'var(--yellow)',outro:'var(--mut)'}
  $p('#dnsT tbody').innerHTML=(k.dns||[]).map(r=>`<tr><td><b>${r.name}</b>.bayerl.cloud</td><td><span class="chip">${r.type}</span></td><td class="mono">${r.content}</td><td><span class="pill" style="color:${tc[r.target]}">${r.target}</span></td></tr>`).join('')
  const w=k.whatsapp||{}; const open=w.state==='open'
  $p('#waCards').innerHTML=pcard('Instância',w.instance||'—','Evolution API',null)+pcard('Estado',`<span style="color:${open?'var(--green)':'var(--yellow)'}">${w.state||'?'}</span>`,open?'conectado ✓':'verifique QR',null)+`<a class="p-card tile" href="https://evo.bayerl.cloud" target="_blank"><div class="l">Painel Evo</div><div class="v" style="font-size:1rem;color:var(--blue)">abrir →</div></a>`
  $p('#dbT tbody').innerHTML=(k.supabase||[]).map(p=>`<tr><td><b>${p.name}</b></td><td>${p.region}</td><td><span class="pill ${/HEALTHY/.test(p.status)?'on':'warn'}">${p.status}</span></td><td>${p.created}</td></tr>`).join('')||'<tr><td colspan=4 style="color:var(--mut)">—</td></tr>'
}

function renderSkills(){
  const q=($p('#skSearch').value||'').toLowerCase()
  const sk=(KNOW.skills||[]).filter(s=>!q||s.name.toLowerCase().includes(q)||(s.desc||'').toLowerCase().includes(q))
  $p('#skGrid').innerHTML=sk.slice(0,200).map(s=>`<div class="tile"><div class="t">⚡ ${s.name}<span class="chip">${s.plugin}</span></div><div class="d">${s.desc||''}</div></div>`).join('')
}

function esc(s){return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')}
function mdRender(md){
  const lines=md.split('\n'); let h='',inTbl=false,inUl=false,inCode=false
  const inl=t=>esc(t).replace(/`([^`]+)`/g,'<code>$1</code>').replace(/\*\*([^*]+)\*\*/g,'<b>$1</b>').replace(/\[([^\]]+)\]\(([^)]+)\)/g,'<a href="$2" target="_blank">$1</a>')
  const closeTbl=()=>{if(inTbl){h+='</tbody></table>';inTbl=false}}, closeUl=()=>{if(inUl){h+='</ul>';inUl=false}}
  for(let ln of lines){
    if(/^```/.test(ln)){inCode=!inCode;h+=inCode?'<pre><code>':'</code></pre>';continue}
    if(inCode){h+=esc(ln)+'\n';continue}
    if(/^\|(.+)\|/.test(ln)){if(/^\|[\s:|-]+\|$/.test(ln))continue;const cells=ln.split('|').slice(1,-1).map(c=>c.trim());if(!inTbl){h+='<table><tbody>';inTbl=true}h+='<tr>'+cells.map(c=>'<td>'+inl(c)+'</td>').join('')+'</tr>';continue}else closeTbl()
    if(/^### /.test(ln)){closeUl();h+='<h3>'+inl(ln.slice(4))+'</h3>';continue}
    if(/^## /.test(ln)){closeUl();h+='<h2>'+inl(ln.slice(3))+'</h2>';continue}
    if(/^# /.test(ln)){closeUl();h+='<h1>'+inl(ln.slice(2))+'</h1>';continue}
    if(/^---/.test(ln)){closeUl();h+='<hr>';continue}
    if(/^[-*] /.test(ln)){if(!inUl){h+='<ul>';inUl=true}h+='<li>'+inl(ln.slice(2))+'</li>';continue}else closeUl()
    if(ln.trim()==='')continue
    h+='<p>'+inl(ln)+'</p>'
  }
  closeTbl();closeUl();return h
}

function drawChart(){
  const W=1000,H=320,pad=34; const svg=$p('#chart'); if(!HIST.length){svg.innerHTML='<text x="500" y="160" fill="#6b7280" text-anchor="middle">coletando dados…</text>';return}
  const pts=HIST.slice(-360); const n=pts.length; const cores=pts[pts.length-1].cores||6
  const X=i=>pad+(i/(n-1||1))*(W-pad*2)
  const series=[['load',pts.map(p=>p.load),cores*1.5,'var(--accent)'],['cpu',pts.map(p=>p.cpu),100,'var(--blue)'],['ram',pts.map(p=>p.ram),100,'var(--purple)']]
  let g=''
  for(let i=0;i<=4;i++){const y=pad+(i/4)*(H-pad*2);g+=`<line x1="${pad}" y1="${y}" x2="${W-pad}" y2="${y}" stroke="#1e1e2e"/>`}
  series.forEach(([nm,vals,max,col])=>{const Y=v=>H-pad-(Math.min(v,max)/max)*(H-pad*2)
    g+=`<polyline fill="none" stroke="${col}" stroke-width="2" points="${vals.map((v,i)=>X(i)+','+Y(v)).join(' ')}"/>`})
  const first=pts[0], last=pts[n-1]
  g+=`<text x="${pad}" y="${H-8}" fill="#6b7280" font-size="12">${new Date(first.t*1000).toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'})}</text>`
  g+=`<text x="${W-pad}" y="${H-8}" fill="#6b7280" font-size="12" text-anchor="end">${new Date(last.t*1000).toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'})}</text>`
  svg.innerHTML=g
  $p('#histInfo').textContent=`${n} pontos · load ${last.load} · cpu ${last.cpu}% · ram ${last.ram}%`
}

let tT; function toast(msg,ok=true){ const e=$p('#toast'); e.textContent=msg; e.style.borderColor=ok?'var(--green)':'var(--red)'; e.classList.add('show'); clearTimeout(tT); tT=setTimeout(()=>e.classList.remove('show'),4000) }

async function act(action,params={},btn){
  if(btn)btn.disabled=true; toast('⏳ '+action+'…')
  try{
    const qs=new URLSearchParams({action,...params}).toString()
    const r=await fetch('/panel/api/?'+qs,{method:'POST'}); const d=await r.json()
    toast((d.ok?'✅ ':'❌ ')+(d.out?d.out.slice(0,120):(d.ok?'feito':'erro')),d.ok)
    setTimeout(loadStats,1800)
  }catch(e){toast('❌ '+e.message,false)}finally{if(btn)setTimeout(()=>btn.disabled=false,1800)}
}

function refreshNow(){ act('refresh'); act('knowledge'); setTimeout(()=>{loadStats();loadKnow()},2500) }

async function loadStats(){ try{ STATS=await(await fetch('/panel/stats.json?t='+Date.now())).json(); renderStats() }catch(e){} }
async function loadKnow(){ try{ KNOW=await(await fetch('/panel/knowledge.json?t='+Date.now())).json(); renderKnow() }catch(e){} }

async function loadMemoryQuality(){
  try{
    const m=await(await fetch('/api/memory/quality-metrics')).json()
    const scoreColor=m.quality_score>=70?'var(--green)':m.quality_score>=40?'var(--yellow)':'var(--red)'
    const pct=v=>((v||0)*100).toFixed(1)+'%'
    $p('#memQualityGrid').innerHTML=`
    <div class="ct-card" style="grid-column:span 2;max-width:260px">
      <div class="ct-head"><span style="font-size:1.5rem;font-weight:800;color:${scoreColor}">${m.quality_score}</span><span style="font-size:.72rem;color:var(--mut);margin-left:.4rem">/100 Quality Score</span></div>
      <div class="ct-row"><span class="ct-label">Conf.</span><div class="ct-bar"><i style="width:${pct(m.avg_confidence)};background:var(--accent)"></i></div><span class="ct-val">${pct(m.avg_confidence)}</span></div>
      <div class="ct-row"><span class="ct-label">Vote</span><div class="ct-bar"><i style="width:${pct(m.helpful_ratio)};background:var(--green)"></i></div><span class="ct-val">${pct(m.helpful_ratio)}</span></div>
      <div class="ct-row"><span class="ct-label">Vec</span><div class="ct-bar"><i style="width:${pct(m.vec_coverage)};background:var(--blue)"></i></div><span class="ct-val">${pct(m.vec_coverage)}</span></div>
      <div style="font-size:.62rem;color:var(--mut);margin-top:.4rem">Idade média: ${(m.age_days_avg||0).toFixed(1)}d · Contradições: ${m.contradiction_count||0}</div>
    </div>
    ${(m.by_category||[]).slice(0,4).map(c=>`<div class="ct-card">
      <div class="ct-head"><span class="ct-dot" style="background:var(--accent)"></span><span class="ct-name">${c.category}</span><span class="ct-img">${c.count}</span></div>
      <div style="font-size:.7rem;color:var(--mut)">conf: ${((c.avg_conf||0)*100).toFixed(0)}%</div>
    </div>`).join('')}
  `}catch(e){$p('#memQualityGrid').innerHTML='<p style="color:var(--mut);font-size:.78rem">sem dados</p>'}
}
async function loadHist(){ try{ HIST=await(await fetch('/panel/history.json?t='+Date.now())).json(); drawChart() }catch(e){} }

let cd=30; function tick(){cd--;if(cd<=0){loadStats();loadHist();loadMemoryQuality();cd=30}$p('#cd').textContent=cd}
setInterval(tick,1000); setInterval(loadKnow,600000)

// ── Widgets da home unificada (10 ideias + bônus) ─────────────────────────────
const _g = id => document.getElementById(id)
const escH = s => String(s==null?'':s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
const agoT = ts => { if(!ts) return ''; let s = (ts>1e12?Math.floor(ts/1000):ts); s = Math.floor(Date.now()/1000)-s; if(s<0)s=0; if(s<60)return s+'s'; if(s<3600)return Math.floor(s/60)+'m'; if(s<86400)return Math.floor(s/3600)+'h'; return Math.floor(s/86400)+'d' }

// #1 — Pulso do cérebro (SSE ao vivo)
const PULSE_COL = { 'memory-save':'#34d399', memory:'#34d399', 'skill-create':'#818cf8', skill:'#818cf8', contradiction:'#f87171', drift:'#fb923c', 'cron-run':'#fbbf24', cron:'#fbbf24', dedup:'#22d3ee', entity:'#22d3ee', relation:'#a78bfa', _:'#64748b' }
let _pulseES = null
function pulsePush(evt){
  const box = _g('brainPulse'); if(!box) return
  const em = box.querySelector('.empty'); if(em) box.innerHTML=''
  const type = evt.type || evt.kind || evt.event || 'evt'
  const txt = evt.text || evt.message || evt.label || evt.content || evt.detail || (typeof evt==='string'?evt:'')
  const col = PULSE_COL[type] || PULSE_COL._
  const ts = evt.at || evt.ts || evt.time || evt.created_at
  const el = document.createElement('div'); el.className='pulse-item'
  el.innerHTML = `<span class="pulse-dot" style="background:${col}"></span><span class="pulse-txt"><b style="color:${col}">${escH(type)}</b> ${escH(String(txt).slice(0,150))}</span><span class="pulse-t">${ts?agoT(ts):''}</span>`
  box.prepend(el)
  while(box.children.length>50) box.lastChild.remove()
}
function startPulse(){
  if(_pulseES) return
  try {
    _pulseES = new EventSource('/api/brain/stream')
    _pulseES.onmessage = e => { try { pulsePush(JSON.parse(e.data)) } catch {} }
    _pulseES.onerror = () => {}
  } catch {}
  setTimeout(()=>{ const box=_g('brainPulse'); if(box && box.querySelector('.empty')) box.innerHTML='<div class="empty">sem eventos recentes</div>' }, 4000)
}

// #2 Saúde + #4 Caixa de decisão + bônus aprendizado ativo (tudo de /api/academia/health)
let _healthCache = null
async function loadHealth(){
  try {
    const h = await fetch('/api/academia/health').then(r=>r.json()); _healthCache = h
    const t = h.stats?.tables || {}
    const conf = h.stats?.avgConfidence ?? 0
    const sc = h.score==null ? '—' : h.score
    const col = h.score>=70 ? 'var(--green)' : h.score>=40 ? 'var(--yellow)' : 'var(--red)'
    if(_g('memHealth')) _g('memHealth').innerHTML =
      `<div class="gauge"><div class="big" style="color:${col}">${sc}</div><div style="font-size:.72rem;color:var(--mut)">Quality Score<br>conf. média ${conf} · ${t.memories||0} memórias ativas</div></div>`
      + (h.signals||[]).filter(s=>s.level!=='action').slice(0,5).map(s=>`<div class="sig ${s.level}"><span class="ic2">${s.level==='ok'?'✅':s.level==='warn'?'⚠️':'ℹ️'}</span><span>${escH(s.text)}</span></div>`).join('')
    // caixa de decisão = sinais acionáveis
    const actions = (h.signals||[]).filter(s=>s.level==='action')
    const pend = (t.contradiction_pending||0)+(t.dedup_pending||0)+(t.proactive_questions||0)
    if(_g('inboxCount')) _g('inboxCount').textContent = pend ? ('• '+pend) : ''
    if(_g('decisionInbox')) _g('decisionInbox').innerHTML = actions.length
      ? actions.map(s=>`<div class="sig action"><span class="ic2">🔔</span><span>${escH(s.text)}</span></div>`).join('') + `<div class="kmut" style="margin-top:.5rem">Resolva respondendo o Orion no WhatsApp.</div>`
      : '<div class="empty">Nada pendente — tudo resolvido ✦</div>'
    // aprendizado ativo (bônus)
    const n = t.proactive_questions || 0
    if(_g('activeLearning')) _g('activeLearning').innerHTML = n
      ? `<div class="gauge"><div class="big" style="color:var(--accent)">${n}</div><div style="font-size:.72rem;color:var(--mut)">pergunta(s) que o Orion quer te fazer<br>para preencher lacunas</div></div>`
      : '<div class="empty">Sem perguntas pendentes — o Orion está confiante ✦</div>'
  } catch(e){ if(_g('memHealth')) _g('memHealth').innerHTML='<div class="empty">sem dados</div>' }
}

// #5 — Sessões Claude ativas
async function loadActiveSessions(){
  try {
    const d = await fetch('/api/claude-sessions?limit=60').then(r=>r.json())
    const all = (d.sessions||[]).filter(s=>!s.hidden)
    const isLive = s => !!(s.active||s.running||s.status==='active')
    const live = all.filter(isLive)
    if(_g('activeCount')) _g('activeCount').textContent = live.length ? ('• '+live.length+' ativa'+(live.length>1?'s':'')) : ''
    const list = live.length ? live : all.slice(0,6)
    if(_g('activeSessions')) _g('activeSessions').innerHTML = list.length ? list.map(s=>{
      const t = s.custom_title||s.ai_title||s.first_user_msg||(s.id||'').slice(0,8)
      const on = isLive(s)
      return `<a class="kitem" href="/sessions/${s.id}"><span style="width:7px;height:7px;border-radius:50%;flex-shrink:0;background:${on?'#22c55e':'#3f3f5a'};${on?'box-shadow:0 0 6px #22c55e':''}"></span><b style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${escH(t)}</b><span class="kmut">${s.message_count||0} msg</span></a>`
    }).join('') : '<div class="empty">nenhuma sessão</div>'
  } catch(e){}
}

// #6 — Próximos crons + sugestões do Haiku
function cronWhen(j){ if(j.next_run){ const d=new Date((j.next_run<1e12?j.next_run*1000:j.next_run)); if(!isNaN(d)) return d.toLocaleString('pt-BR',{day:'2-digit',month:'2-digit',hour:'2-digit',minute:'2-digit'}) } return j.schedule||'' }
async function loadCrons(){
  try {
    const [c, sg] = await Promise.all([
      fetch('/api/cron').then(r=>r.json()),
      fetch('/api/cron/suggestions').then(r=>r.json()).catch(()=>({}))
    ])
    const jobs = (c.jobs||[]).filter(j=>j.status!=='deleted')
    const active = jobs.filter(j=>j.status==='active')
    if(_g('cronCount')) _g('cronCount').textContent = '• '+active.length
    const sug = sg.suggestions || sg.items || []
    if(_g('cronTimeline')) _g('cronTimeline').innerHTML =
      (active.length ? active.slice(0,8).map(j=>`<div class="kitem"><span style="color:#fbbf24">⏰</span><b style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${escH(j.name||j.description||'job')}</b><span class="kmut">${escH(cronWhen(j))}</span></div>`).join('') : '<div class="empty">nenhum cron ativo</div>')
      + (sug.length ? `<div class="kmut" style="margin:.6rem 0 .3rem">💡 sugestões do Haiku</div>`+sug.slice(0,3).map(s=>`<div class="kitem" style="background:#0d0d1a"><span>✨</span><span style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${escH(s.name||s.task_prompt||'')}</span><span class="kmut">${escH(s.schedule||'')}</span></div>`).join('') : '')
  } catch(e){}
}

// #8 — Top skills aprendidas
async function loadTopSkills(){
  try {
    const d = await fetch('/api/brain/skills').then(r=>r.json())
    const sk = (d.skills||[]).slice().sort((a,b)=>(b.usage_count||0)-(a.usage_count||0)).slice(0,8)
    if(_g('skillsCount')) _g('skillsCount').textContent = '• '+(d.counts?.total ?? sk.length)
    if(_g('topSkills')) _g('topSkills').innerHTML = sk.length ? sk.map(s=>`<div class="kitem"><span style="color:#818cf8">⚡</span><b style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="${escH(s.description)}">${escH(s.name)}</b>${s.autoGenerated?'<span class="chip">auto</span>':''}<span class="kmut">${s.usage_count||0}×</span>${s.rejection_pct?`<span class="kmut" style="color:var(--red)">${s.rejection_pct}%✗</span>`:''}</div>`).join('') : '<div class="empty">nenhuma skill ainda</div>'
  } catch(e){}
}

// #3 — Composição da memória
async function loadMemGrowth(){
  try {
    const d = await fetch('/api/memory/stats').then(r=>r.json())
    const types = d.by_type||{}; const tot = d.total||1
    const tcol = { raw:'#fbbf24', episodic:'#34d399', semantic:'#c084fc', skill:'#818cf8' }
    const rows = Object.entries(types).sort((a,b)=>b[1]-a[1])
    if(_g('memGrowth')) _g('memGrowth').innerHTML =
      `<div style="display:flex;gap:1.2rem;margin-bottom:.8rem">
        <div><div style="font-size:1.6rem;font-weight:800">${d.total||0}</div><div class="kmut">ativas</div></div>
        <div><div style="font-size:1.6rem;font-weight:800;color:var(--mut)">${d.archived||0}</div><div class="kmut">arquivadas</div></div>
        <div><div style="font-size:1.6rem;font-weight:800;color:var(--blue)">${Math.round((d.vec_coverage||0)*100)}%</div><div class="kmut">c/ vetor</div></div>
      </div>`
      + rows.map(([k,v])=>`<div class="minirow"><span class="ml">${escH(k)}</span><div class="mb"><i style="width:${(v/tot*100).toFixed(0)}%;background:${tcol[k]||'#64748b'}"></i></div><span class="mv">${v}</span></div>`).join('')
  } catch(e){}
}

// #7 — Mini knowledge-graph (resumo + link)
async function loadMiniGraph(){
  try {
    const d = await fetch('/api/brain/graph?max=120').then(r=>r.json())
    const s = d.stats||{}
    if(_g('miniGraph')) _g('miniGraph').innerHTML =
      `<div class="hgrid3" style="gap:.5rem;margin-bottom:.7rem">`
      + [['nós',s.nodes],['arestas',s.edges],['memórias',s.memories],['relações',s.relations],['causais',s.causal],['contradições',s.contradictions]].map(([l,v])=>`<div style="background:#0f0f1a;border-radius:8px;padding:.5rem .65rem"><div style="font-size:1.25rem;font-weight:800">${v||0}</div><div class="kmut">${l}</div></div>`).join('')
      + `</div><a class="btn" href="/brain">🕸️ abrir cérebro ao vivo →</a>`
  } catch(e){}
}

// #9 — Atividade por canal
async function loadChannels(){
  try {
    const d = await fetch('/api/sessions').then(r=>r.json())
    const by = {}; (d.sessions||[]).forEach(s=>{ const c=s.channel||'?'; by[c]=(by[c]||0)+1 })
    const ic = { whatsapp:'📱', plugin:'💻', chat_ui:'🌐', cron:'⏰', neo:'🧬' }
    const tot = Object.values(by).reduce((a,b)=>a+b,0)||1
    const rows = Object.entries(by).sort((a,b)=>b[1]-a[1])
    if(_g('channelActivity')) _g('channelActivity').innerHTML = rows.length ? rows.map(([k,v])=>`<div class="minirow"><span class="ml">${ic[k]||'🔗'} ${escH(k)}</span><div class="mb"><i style="width:${(v/tot*100).toFixed(0)}%;background:var(--accent)"></i></div><span class="mv">${v}</span></div>`).join('') : '<div class="empty">—</div>'
  } catch(e){}
}

// #10 — Uso & custo de IA
async function loadAiCost(){
  try {
    const d = await fetch('/api/claude-usage').then(r=>r.json())
    const bar = (lbl,o) => o ? `<div class="minirow"><span class="ml">${lbl}</span><div class="mb"><i style="width:${o.pct}%;background:${usageColor(o.pct)}"></i></div><span class="mv">${o.pct}%</span></div>` : ''
    if(_g('aiCost')) _g('aiCost').innerHTML = `${bar('Sessão 5h',d.session)}${bar('Semana 7d',d.week)}<div class="kmut" style="margin-top:.6rem">Crons Haiku em background: Fase 2 (30min) · Fase 3 (6h) · Fase 4 (meia-noite) — ~$0,001–0,003 por rodada.</div>`
  } catch(e){}
}

// bônus — cadeias causais
async function loadCausal(){
  try {
    const d = await fetch('/api/memories/causal?limit=8').then(r=>r.json())
    const links = d.links||[]
    if(_g('causalBox')) _g('causalBox').innerHTML = links.length ? links.slice(0,8).map(l=>`<div class="kitem"><span style="flex:1"><b style="color:#a78bfa">${escH(l.cause)}</b> <span style="color:#374151">→</span> <b style="color:#fb923c">${escH(l.effect)}</b></span><span class="kmut">${Math.round((l.confidence||0)*100)}%</span></div>`).join('') : '<div class="empty">nenhuma cadeia causal ainda</div>'
  } catch(e){}
}

// bônus — índice temporal
async function loadTemporal(){
  try {
    const d = await fetch('/api/memories/temporal/stats').then(r=>r.json())
    const entries = Object.entries(d||{}).filter(([k,v])=>typeof v==='number')
    if(_g('temporalBox')) _g('temporalBox').innerHTML = entries.length ? entries.slice(0,8).map(([k,v])=>`<div class="minirow"><span class="ml" style="width:auto;flex:1">${escH(k)}</span><span class="mv" style="width:auto">${v}</span></div>`).join('') : '<div class="empty">sem eventos temporais</div>'
  } catch(e){}
}

// init da home unificada
function initHome(){
  loadStats(); loadKnow(); loadHist(); loadMemoryQuality()
  startPulse()
  loadHealth(); loadActiveSessions(); loadCrons(); loadTopSkills()
  loadMemGrowth(); loadMiniGraph(); loadChannels(); loadAiCost(); loadCausal(); loadTemporal()
  setInterval(()=>{ loadHealth(); loadActiveSessions(); loadCrons() }, 30000)
  setInterval(()=>{ loadTopSkills(); loadMemGrowth(); loadMiniGraph(); loadChannels(); loadAiCost(); loadCausal(); loadTemporal() }, 90000)
}
initHome()

// ── CLAUDE.md editor ─────────────────────────────────────────────────────────

const CMD_LABELS = {
  global:        { label:'Global', scope:'toda sessão Claude Code', color:'#6366f1', tag:'GLOBAL' },
  workspace:     { label:'Workspace', scope:'quando cwd = /config/workspace', color:'#22c55e', tag:'WORKSPACE' },
  brandspace:    { label:'Brandspace', scope:'injetado por buildFullContext + cwd do projeto', color:'#f472b6', tag:'PROJETO' },
  trackingmachine:{ label:'TrackingMachine', scope:'injetado por buildFullContext + cwd do projeto', color:'#f472b6', tag:'PROJETO' },
  ralab:         { label:'Ralab', scope:'injetado por buildFullContext + cwd do projeto', color:'#f472b6', tag:'PROJETO' },
  fisioexpert:   { label:'FisioExpert', scope:'injetado por buildFullContext + cwd do projeto', color:'#f472b6', tag:'PROJETO' },
  abcprime:      { label:'ABC Prime', scope:'injetado por buildFullContext + cwd do projeto', color:'#f472b6', tag:'PROJETO' },
  orion:         { label:'Orion', scope:'injetado por buildFullContext + cwd do projeto', color:'#f472b6', tag:'PROJETO' },
}

let cmdCurrentKey = null

async function loadCmdFileList() {
  try {
    const data = await (await fetch('/api/claudemd/list')).json()
    const wrap = document.getElementById('cmd-file-list')
    if (!wrap) return
    wrap.innerHTML = data.files.map(f => {
      const info = CMD_LABELS[f.key] || { label: f.key, scope: '', color: '#6b7280', tag: '?' }
      const existsBadge = f.exists
        ? `<span style="color:#22c55e;font-size:.7rem;font-weight:700">✅ existe</span>`
        : `<span style="color:#ef4444;font-size:.7rem;font-weight:700">✗ não existe</span>`
      const sizeTxt = f.exists ? `<span style="color:#4b5563;font-size:.7rem">${f.size} chars</span>` : ''
      return `<div onclick="openCmdEditor('${f.key}')" style="display:flex;align-items:center;gap:12px;padding:10px 16px;border-bottom:1px solid var(--line);cursor:pointer;transition:.12s" onmouseover="this.style.background='#111118'" onmouseout="this.style.background=''">
        <div style="width:8px;height:8px;border-radius:50%;background:${info.color};flex-shrink:0"></div>
        <div style="flex:1">
          <div style="display:flex;align-items:center;gap:.5rem">
            <span style="font-size:.85rem;font-weight:700;color:#e5e7eb">${info.label}</span>
            <span style="font-size:.65rem;font-weight:700;background:#1a1a2e;color:${info.color};padding:1px 6px;border-radius:4px">${info.tag}</span>
            ${existsBadge} ${sizeTxt}
          </div>
          <div style="font-size:.72rem;color:#6b7280;margin-top:.15rem;font-family:monospace">${f.path}</div>
          <div style="font-size:.72rem;color:#4b5563;margin-top:.1rem">${info.scope}</div>
        </div>
        <span style="color:#374151;font-size:.85rem">✏️</span>
      </div>`
    }).join('')
  } catch(e) { console.error('loadCmdFileList:', e) }
}

async function openCmdEditor(key) {
  cmdCurrentKey = key
  const info = CMD_LABELS[key] || { label: key }
  document.getElementById('cmd-editor-title').textContent = `Editando: ${info.label} CLAUDE.md`
  document.getElementById('cmd-editor-wrap').style.display = 'block'
  document.getElementById('cmd-editor-ta').value = 'carregando…'
  try {
    const data = await (await fetch(`/api/claudemd?key=${key}`)).json()
    document.getElementById('cmd-editor-ta').value = data.content
  } catch(e) {
    document.getElementById('cmd-editor-ta').value = `# Erro ao carregar: ${e.message}`
  }
  document.getElementById('cmd-editor-wrap').scrollIntoView({ behavior:'smooth' })
}

async function saveCmdMd() {
  if (!cmdCurrentKey) return
  const content = document.getElementById('cmd-editor-ta').value
  try {
    const r = await fetch('/api/claudemd', {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ key: cmdCurrentKey, content })
    })
    const data = await r.json()
    if (data.ok) {
      showToast('✅ Salvo com sucesso')
      loadCmdFileList()
    } else {
      showToast('❌ Erro: ' + (data.error || 'desconhecido'))
    }
  } catch(e) { showToast('❌ ' + e.message) }
}

function closeCmdEditor() {
  cmdCurrentKey = null
  document.getElementById('cmd-editor-wrap').style.display = 'none'
}

// Carrega quando entrar na aba doc-claudemds
const _origDocNav = document.querySelectorAll.bind(document)
document.addEventListener('click', e => {
  const btn = e.target.closest('.nav-item[data-view="doc-claudemds"]')
  if (btn) loadCmdFileList()
})

// ── Metricas (grafico filtravel por consumo) ──────────────────────────────
let _mfEnt = null
let _mf = { kind:'container', name:'', metric:'cpu', range:'1h' }
async function loadMetricEntities(){ try{ _mfEnt = await (await fetch('/api/metrics/entities')).json(); fillMetricSelects() }catch(e){} }
function fillMetricSelects(){
  if(!_mfEnt) return
  const list = _mfEnt[_mf.kind] || []
  const sn = $p('#mfName'); if(sn){ sn.innerHTML = list.map(n=>`<option value="${n}">${n.replace(/^stack-/,'').replace(/-1$/,'')}</option>`).join('')||'<option>(sem dados)</option>'; if(list.length){ if(!list.includes(_mf.name)) _mf.name=list[0]; sn.value=_mf.name } }
  const sm = $p('#mfMetric'); if(sm){ sm.innerHTML = _mf.kind==='server'
    ? '<option value="cpu">CPU %</option><option value="mem_pct">Memoria %</option><option value="swap_pct">Swap %</option><option value="disk_pct">Disco %</option>'
    : '<option value="cpu">CPU %</option><option value="mem_mb">Memoria (MB)</option>'
    if(![...sm.options].some(o=>o.value===_mf.metric)) _mf.metric='cpu'; sm.value=_mf.metric }
}
async function drawMetric(){
  if(!_mf.name){ return }
  try{
    const d = await (await fetch(`/api/metrics?kind=${_mf.kind}&name=${encodeURIComponent(_mf.name)}&metric=${_mf.metric}&range=${_mf.range}`)).json()
    renderMetricChart(d.points||[])
    const unit = _mf.metric==='mem_mb'?' MB':'%'
    const last = d.points?.length?d.points[d.points.length-1].v:null
    $p('#metricInfo') && ($p('#metricInfo').textContent = (d.points?.length||0)+' pontos · '+_mf.range+(last!=null?(' · agora: '+last+unit):''))
  }catch(e){}
}
function renderMetricChart(pts){
  const svg=$p('#metricChart'); if(!svg) return
  if(!pts.length){ svg.innerHTML='<text x="500" y="150" fill="#6b7280" text-anchor="middle" font-size="13">sem dados ainda neste periodo (vai preenchendo com o tempo)</text>'; return }
  const W=1000,H=300,pad=42
  const xs=pts.map(p=>p.t), ys=pts.map(p=>p.v)
  const minX=Math.min(...xs), maxX=Math.max(...xs), maxY=Math.max(...ys,1)
  const X=t=>pad+(t-minX)/((maxX-minX)||1)*(W-2*pad)
  const Y=v=>H-pad-(v/maxY)*(H-2*pad)
  const line=pts.map((p,i)=>(i?'L':'M')+X(p.t).toFixed(1)+' '+Y(p.v).toFixed(1)).join(' ')
  const area='M'+X(pts[0].t).toFixed(1)+' '+(H-pad)+' '+pts.map(p=>'L'+X(p.t).toFixed(1)+' '+Y(p.v).toFixed(1)).join(' ')+' L'+X(pts[pts.length-1].t).toFixed(1)+' '+(H-pad)+' Z'
  const grid=[0,.5,1].map(f=>{const v=maxY*f, y=Y(v); return `<line x1="${pad}" y1="${y.toFixed(1)}" x2="${W-pad}" y2="${y.toFixed(1)}" stroke="#1e1e2e" stroke-width="1"/><text x="${pad-7}" y="${(y+4).toFixed(1)}" fill="#6b7280" font-size="11" text-anchor="end">${v.toFixed(0)}</text>`}).join('')
  const fmt=t=>{const d=new Date(t*1000); return _mf.range==='1h'||_mf.range==='1d'?(('0'+d.getHours()).slice(-2)+':'+('0'+d.getMinutes()).slice(-2)):(('0'+d.getDate()).slice(-2)+'/'+('0'+(d.getMonth()+1)).slice(-2))}
  const xlab=[0,Math.floor(pts.length/2),pts.length-1].filter((x,i,a)=>a.indexOf(x)===i).map(i=>`<text x="${X(pts[i].t).toFixed(1)}" y="${H-14}" fill="#6b7280" font-size="11" text-anchor="middle">${fmt(pts[i].t)}</text>`).join('')
  svg.innerHTML=`${grid}<path d="${area}" fill="rgba(99,102,241,.16)"/><path d="${line}" fill="none" stroke="#6366f1" stroke-width="2" stroke-linejoin="round"/>${xlab}`
}
function initMetrics(){
  const sk=$p('#mfKind'); if(!sk) return
  sk.onchange=e=>{ _mf.kind=e.target.value; fillMetricSelects(); drawMetric() }
  $p('#mfName').onchange=e=>{ _mf.name=e.target.value; drawMetric() }
  $p('#mfMetric').onchange=e=>{ _mf.metric=e.target.value; drawMetric() }
  $$p('.mfr').forEach(b=>b.onclick=()=>{ _mf.range=b.dataset.r; $$p('.mfr').forEach(x=>x.classList.remove('active')); b.classList.add('active'); drawMetric() })
  loadMetricEntities().then(drawMetric)
  setInterval(()=>{ if(_mf.range==='1h') drawMetric() }, 60000)
}
setTimeout(initMetrics, 2000)

</script>
</body>
</html>
