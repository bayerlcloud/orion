import { execa } from 'execa'
import { SESSION_CWD } from './reader.js'
import { randomUUID } from 'crypto'

// Mapa de sessões ativas (enviando mensagem): sessionId → true
const activeSends = new Map()

export function isSending(sessionId) {
  return activeSends.get(sessionId) === true
}

export async function sendToSession(sessionId, message, model = null) {
  if (activeSends.get(sessionId)) {
    throw new Error('Sessão ocupada — aguarde a resposta anterior')
  }

  activeSends.set(sessionId, true)
  try {
    const result = await execa('claude', [
      '--resume', sessionId,
      '-p', message,
      '--output-format', 'json',
      '--dangerously-skip-permissions',
      ...(model ? ['--model', model] : []),
    ], {
      cwd: SESSION_CWD,
      timeout: 300_000, // 5 min
      env: { ...process.env },
    })

    const parsed = JSON.parse(result.stdout)
    return parsed.result ?? parsed.content ?? ''
  } finally {
    activeSends.delete(sessionId)
  }
}

// Cria uma nova sessão com uma primeira mensagem.
// Gera UUID próprio e usa --resume para criar o arquivo JSONL com ID conhecido.
// O fs.watch no SESSIONS_DIR detecta o novo arquivo e o indexer passa a servir via SSE.
export function createNewSession(message, model = null) {
  const newId = randomUUID()
  execa('claude', [
    '--resume', newId,
    '-p', message,
    '--output-format', 'json',
    '--dangerously-skip-permissions',
    ...(model ? ['--model', model] : []),
  ], {
    cwd: SESSION_CWD,
    timeout: 300_000,
    env: { ...process.env },
  }).catch(err => console.error('[sessions] createNew:', err.message))
  return newId  // retorna imediatamente — a resposta chega via SSE
}
